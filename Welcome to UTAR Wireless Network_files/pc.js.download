/*
 * 此文件用于扩展当前模块的功能，新增dom或其他逻辑请不要在模板文件处理
 * 请统一放置在扩展文件处理，便于以后模块文件替换时不覆盖新增的功能
 */
(function(){
    // ADD begin

    //新增认证客户端下载
    var enableCliauth = getUrlParam("enable_cliauth"),
        acip = getUrlParam("acip"),
        clientDownload = $('.tool.client'),
        downloadLink = $('.tool.client a');

    //如果url中的参数cliauth === '1'则显示下载链接;
    if (enableCliauth === '1' && downloadLink[0]) {
        clientDownload.show();

        //如果url中包含acip参数，则将cip拼接到下载链接

        //var initHref = downloadLink[0].getAttribute('href');
        downloadLink[0].setAttribute('href', 'http://' + (acip ? acip : window.location.hostname) + ':817/singress.exe');

    }
})();