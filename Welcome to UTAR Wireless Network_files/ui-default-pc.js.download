/*--------------------------------------------------
这个文件主要处理ui上的效果,布局初始化等，一般定制可能会
改这个文件
----------------------------------------------------*/

/**
 * 是否是无感知登录，如果链接上携带noSense!=0,则需要通过请求接口判断该认证方式是否需要无感知
 * 返回参数 nosense=1，则是需要无感知登录，隐藏body，直接调用登录函数
 * 其他情况则走默认流程
 */
 var noSenseList = {
	saml: {
		noSenseCondition: getUrlParam('nosense') !== '0', //需要请求无感知接口的条件
		api: '/ac_portal/saml_need_nosense?auth_type=saml&_ID_=' + getParamFromUrl('_ID_'), //请求无感知接口
		loginFun: function(){  			//如果需要无感知执行的函数，一般是自动录
			openHref("/ac_portal/get_auth_url?auth_type=saml"); 
		}
	}
};

/*
	pc版的在ipad的qq浏览器下面会有问题，所以统一转到手机版浏览
*/
if (navigator.userAgent.toLowerCase().indexOf('ipad') > -1 && $("link")[0].href.indexOf("mobile.css") < 0) {
	window.location = window.location.href.replace("pc.html", "mobile.html");
}

/*
     根据参数是否有appId来控制显示那种微信认证方式
 */
function syncWechatDiv() {
	var appId = getUrlParam('appId'),
		$wechat = $('#mode_wechat'),
		$qrcode = $wechat.find('.wechat_qrcode'),
		$account = $wechat.find('.wechat_account'),
		$wifi = $wechat.find('.wechat_wifi'),
		$real_wifi = $wechat.find('.statement-content');

	if (appId) {
		$account.hide();
		$wechat.css('paddingTop', '20px');
		createWechatWifiQR();
	} else {
		$real_wifi.hide();
	}

	$qrcode.hide();
	$wifi.hide();
}

//显示微信
function showWechatImg(type) {
	var h = $(document).height();
	var w = $(document).width();
	var navStr = navigator.userAgent.toLowerCase(),
		isIE = navStr.indexOf("msie") > 0,
		isIE8 = navStr.indexOf("msie 8") > 0,
		isIE7 = navStr.indexOf("msie 7") > 0,
		isIE6 = navStr.indexOf("msie 6") > 0;
	if (isIE8 || isIE8 || isIE6) {
		h = h - 10;
	}

	// 微信连wifi需生成二维码
	if (type === 'wifi') {
		createWechatWifiQR();
	}

	$('#statement_' + type).height(h);
	$('#statement_' + type).fadeIn('fast');
}

function hideWechatImg(type) {
	$('#statement_' + type).fadeOut('fast');
}

// 使用腾讯提供的API生成二维码用于微信连wifi
function createWechatWifiQR() {
	/*JSAPI.auth({
        target : document.getElementById('qrcode_zone'),
        appId : getUrlParam('appid'),
        shopId : getUrlParam('shopid'),
        extend : 'sangfor',
        authUrl : "http://" + window.location.host + "/wx_wifi/index.htm?ispc=1"
    });*/
	//不支持微信了，用二维码假装一下
	if (window.is_create_wechart_qrcode) {
		return;
	}
	var url = create_qrcode_url('wechat');

	$("#qrcode_zone").html(create_qrcode(url, "10"));

	window.is_create_wechart_qrcode = true;
}


//初始化页面，这个函数只会运行一次(定制不用改动)
function initPage() {
	var tabs = getUrlParam('tabs').split('-');
	var fristTab = tabs[0];
    var isPreview = getUrlParam('isPreview');

	// 只有一个other_oauth时不进入上网认证系统页面，直接进入该认证的登录页面
	if (tabs.length === 1 && fristTab === 'other_oauth' && isPreview !== "1") {
		$('.pc-body').hide();
		openHref("/ac_portal/get_auth_url?auth_type=other_oauth");
 
	} else if (noSenseList.hasOwnProperty(fristTab) && isPreview !== "1") {
		if(noSenseList[fristTab].noSenseCondition) {
			$('.pc-body').hide();
			$.ajax({
				url: noSenseList[fristTab].api,
				type: "GET",
				success: function(resp) {
					var json = json_decode(resp);
					if (json && json.success) {
						if(json.nosense === 1){
							noSenseList[fristTab].loginFun();
						}else{
							initTodo();	
						}	
					} else {
						initTodo();
					}
				},
				error: function() {
					initTodo();
				}
			})
		}else{
			initTodo();
		}
	}else {
		initTodo();
	}
}

//默认初始化页面
function initTodo() {
	$('.pc-body').show();
	initChangeTabMethod();
	var type = getUrlParam("type"),
		firstTab = '';
	var username = getUrlParam("username");

	var policy = getUrlParam("policy");
	var policyType = getUrlParam("policy_type");
	var errorMsg = getUrlParam("errorMsg");
	//重定向到完善信息页面
	if (policy && policyType === "terminal") {
		activatePage("completeUserIndex", username);
	} else {
		activatePage(type, username, true, errorMsg);
		initTabs();
	}

	//初始化查看流量信息的url
	$id("flux").href = "https://" + document.domain + "/cgi-bin/showflux.cgi?user=" + encodeURIComponent(username);

	if (window.top.location.search.indexOf('is_preview') === -1) {
		initPstrength();
	}
	//初始化oauth认证的链接，包括 qywechat/dingtalk/moa/facebook/line/twitter/gmail/cas/第三方
	initOauthLink();
	//如果认证方式包含other_oauth即第三方oauth认证时，提前获取图片的base64编码
	initOtherOauthIcon();
	//如果认证方式是saml认证时，提前获取图片的base64编码
	initSamlOauthIcon();
}
//初始化oauth认证的链接
function initOauthLink() {
	$("#oauth_gmail_hidden_a").click = function() {
		openHref("/ac_portal/get_auth_url?auth_type=gmail");
	}
	$('.oauth-icon-wrap').each(function() {
		if ($(this).attr("mode-type") !== "cas") {
			$(this).click(function() {
                openHref("/ac_portal/get_auth_url?auth_type=" + $(this).attr("mode-type"));
			});
		} else {
			$(this).click(function() {
                openHref(decodeURIComponent(getUrlParam("cas_url")));
			});
		}

	});

}


function createQrcode() {
	if (window.is_create_qrcode) {
		return false;
	}
	var url = create_qrcode_url();

	$("#qrcodeImg").html(create_qrcode(url, "10"));
	//访客二维码填写信息项后的二维码与原二维码生成一致
	$("#qrcodeImgInfo").html(create_qrcode(url, "10"));
	window.is_create_qrcode = true;
}

$(document).ready(function() {
	initPage();
});

//下面这块主要处理输入框，按钮，提示信息的样式变化(不用动)
(function($) {
	function js_alert(divid, msg, noEncode, jump) {
		var msg_box = $("#" + divid + " .login_box_msg");
		if (msg == "") {
			if (/MQQBrowser/.test(navigator.userAgent)) {
				msg_box.hide();
			} else {
				msg_box.slideUp();
			}

		} else {
			if (/MQQBrowser/.test(navigator.userAgent)) {
				msg_box.show();
			} else {
				msg_box.slideDown();
			}

		}
		var tip = msg;
		if (!noEncode) {
			msg = htmlEncode(msg);
		}
		msg_box.find("dd").attr('title', tip).html(msg + (jump || ''));
	}

	window.js_alert = js_alert;

	// JavaScript Document
	$(document).ready(function() {
		login_operate();
		btn();
		//输入框大小写提示
		$(":password").keypress(detectCapsLock);
		//输入框回车提交
		$("input").keyup(onInputKeyUp);
	});

	//输入框
	function login_operate() {
		var li = $(".login_operate ul li");
		var input = $(".login_operate ul li.password input");
		var li_hover = "li_hover";
		var li_press = "li_press";
		var phone_input = $(".phone input");
		var sms_input = $(".sms input");
		var username_input = $(".username input");
		var password_input = $(".password input");
		var password_input_new = $(".password_new input");
		var password_input_n = $(".password_n input");

		/*聚焦*/
		$(".focus").focus();
		/*选中*/
		$(input).click(function() {
			$(this).select();
		});

		//提示
		var inputs = $('.input');
		var showLabel = function(opacity) {
			var v = this.value;
			if (this.type !== "password") {
				v = $.trim(v);
			}
			if (v === '') {
				$(this).siblings('label').show();
				$(this).siblings('label').css('opacity', opacity);
			} else {
				$(this).siblings('label').hide();
			}
		}

		inputs.bind('focus', function() {
			showLabel.call(this, 0.5);
		}).bind('keydown', function() {
			$(this).siblings('label').hide();
		}).bind('blur', function() {
			var v = this.value;
			if (this.type !== "password") {
				v = $.trim(v);
			}
			if (v === '') {
				this.value = v;
			}
			showLabel.call(this, 1);
		});
		setTimeout(function() {
			$.each(inputs, function(index, item) {
				if ($.trim(this.value) !== '') {
					$(item).siblings('label').css('opacity', 0);
				}
			});
		}, 800);

		if (!/(Mobile|Android|Windows Phone)/.test(navigator.userAgent)) {
			/*悬停与聚焦后效果*/
			li.hover(function() {
				$(this).addClass(li_hover);
			}, function() {
				$(this).removeClass(li_hover);
			});
		}
		$(".sms_go").hover(function() {
			$(this).removeClass(li_hover);
		});

		$(phone_input).focus(function() {
			$(".phone").addClass(li_press);
		});
		$(phone_input).blur(function() {
			$(".phone").removeClass(li_press);
		});

		$(sms_input).focus(function() {
			$(".sms").addClass(li_press);
		});
		$(sms_input).blur(function() {
			$(".sms").removeClass(li_press);
		});

		$(username_input).focus(function() {
			$(".username").addClass(li_press);
		});
		$(username_input).blur(function() {
			$(".username").removeClass(li_press);
		});

		$(password_input).focus(function() {
			$(".password").addClass(li_press);
		});
		$(password_input).blur(function() {
			$(".password").removeClass(li_press);
		});

		$(password_input_new).focus(function() {
			$(".password_new").addClass(li_press);
		});
		$(password_input_new).blur(function() {
			$(".password_new").removeClass(li_press);
		});

		$(password_input_n).focus(function() {
			$(".password_n").addClass(li_press);
		});
		$(password_input_n).blur(function() {
			$(".password_n").removeClass(li_press);
		});

	};
	//按钮
	function btn() {
		var btn = $(".login_btn");
		$(btn).hover(function() {
			$(this).addClass("login_btn_hover");
		}, function() {
			$(this).removeClass("login_btn_hover");
		});
		$(btn).mousedown(function() {
			$(this).addClass("login_btn_press");
		});
		$(btn).mouseup(function() {
			$(this).removeClass("login_btn_press");
		});
	};
	/*检测大写锁定*/
	function detectCapsLock(ae) {
		var uO = ae.keyCode || ae.charCode,
			formid = "mode_password",
			Uc = ae.shiftKey;
		if (this.id.indexOf("changePwd") > -1) {
			formid = "mode_changePwd";
		}
		if ((uO >= 65 && uO <= 90 && !Uc) || (uO >= 97 && uO <= 122 && Uc)) {
			js_alert(formid, "Caps Lock is On.");
		} else if ((uO >= 97 && uO <= 122 && !Uc) || (uO >= 65 && uO <= 90 && Uc)) {
			js_alert(formid, "");
		} else {
			js_alert(formid, "");
		}
	};
	//处理输入框回车事件
	function onInputKeyUp(e) {
		if (e.keyCode === 13) { //enter事件
			var submitBtn = $("#" + this.id.split("_")[0] + "_submitBtn");
			if (submitBtn && submitBtn.length > 0) { //sms可见 
				submitBtn.click();
				return false;
			}
		}
	}
})(jQuery);