}
//会议室二维码pc端输入二维码ID之后的处理
function onMtQrcode() {
	var r = randomNum(0, 99),
		t = (new Date()).getTime(),
		c = r * t;
	var qcid = $("#mtqrcode_id").val(),
		ip = getUrlParam("ip"),
		controller_type = getUrlParam("controller_type"),
		id = getUrlParam("_ID_");
	var url = '/ac_portal/mtqrcode.html?' + "&qcid=" + qcid + "&r=" + r + "&c=" + c + "&t=" + t + "&pc=1" + "&ip=" + ip + "&controller_type=" + controller_type + "&_ID_=" + id + "&flag=1";
	$.ajax({
		type: 'GET',
		url: url,
		success: function(json) {
			var json = json_decode(json);
			if (json.success) {
                getMtQrcodeSysFields();
			} else {
				js_alert("mode_mtqrcode", json.msg || _("Network connection error occurred."));
			}
		},
		error: function(json) {
			js_alert("mode_mtqrcode", _("Network connection error occurred."));
		}
	});
}

//忘记密码第一步骤时点击下一步
function onForgetFirstStep(stepsArr, num) {
	var params = {
		opr: 'checkAuthCode',
		authCode: $("#find_pwd_code").val(),
		userAccount: $("#find_pwd_username").val()
	};
	var mailReg = /^(\w-*\.*)+@(\w-?)+(\.\w{2,})+$/,
		mobileReg = /^\d{1,20}$/;
	if (!mailReg.test(params.userAccount) && !mobileReg.test(params.userAccount)) {
		js_alert("mode_forgetPwd", _("Please enter a valid mobile phone number."));
		return;
	}
	if (params.authCode === "") {
		js_alert(mode_forgetPwd, _("Verification code"));
		return;
	}
	$.ajax({
		url: g_forgetUrl,
		data: params,
		type: "POST",
		success: function(json) {
			var json = json_decode(json);
			if (json.success) {
				$("#forget_second_step_username").attr('value', json.username);
				g_forgetToken = json.token;
				for (var i = 0; i < stepsArr.length; i++) {
					if (i === num) {
						stepsArr[i].show();
					} else {
						stepsArr[i].hide();
					}
				}
			} else {
				js_alert("mode_forgetPwd", json.msg || _("Network connection error occurred."));
			}
		},
		error: function(o) {

		}
	});

}
//忘记密码时发送验证码事件
function onForgetGetSmsCode() {
	var params = {
		opr: 'getAuthCode',
		userAccount: $("#find_pwd_username").val()
	}
	cookie.set("forgetPwdPhoneNumber", $id("find_pwd_username").value, g_remberTime);
	var codeBtnID = "forget_getSmsCode";
	$.ajax({
		url: g_forgetUrl,
		data: params,
		type: "POST",
		success: function(json) {
