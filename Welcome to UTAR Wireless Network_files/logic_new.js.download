			if (json.success) {
				js_alert("mode_forgetPwd", _('One-time passcode (OTP) was sent.'));
				afterGetAllCodeState({
					success: true
				}, {
					
				}, "mode_forgetPwd", $id(codeBtnID), 60, 'forgetpwd');
			} else {
				js_alert("mode_forgetPwd", json.msg || _('Network connection error occurred.'));
			}
		},
		error: function(o) {
			js_alert("mode_forgetPwd", _('Failed to send request.'));
		}
	});
}
//提交重置新密码的确定按钮
function onForgetPwd() {
	if (!forgetPwdValidator()) return;
	var rckey = +(new Date()) + '';
	var pwd = do_encrypt_rc4($id("find_pwd_pwd").value, rckey);
	var pwdCon = do_encrypt_rc4($id("find_pwd_pwdcon").value, rckey);

	var params = {
		opr: 'updatePassword',
		name: $("#find_pwd_username").val(),
		password: pwd,
		password_repeat: pwdCon,
		auth_tag: rckey,
		token: g_forgetToken
	}
	$.ajax({
		url: g_forgetUrl,
		data: params,
		type: "POST",
		success: function(json) {
			json = json_decode(json);
			if (json.success) {
                countdown({
					time: 3,
					msgCallback: function(time){
                        js_alert("mode_forgetPwd", _("Password was found. It goes back " + time + ' later.'));
					},
					callback: function(){
                        activatePage('frontLogin');
                        //$('#find_pwd_username').attr('value', '');
                        //$('#find_pwd_code').attr('value', '');
                        //$('#find_pwd_pwd').attr('value', '');
                        //$('#find_pwd_pwdcon').attr('value', '');
                        js_alert("mode_forgetPwd", '');
                        moveToStep(0);
                    }
				});

			} else{
				js_alert("mode_forgetPwd", json.msg || _("Failed to find password."));
			}
		},
		error: function(o) {
			js_alert("mode_forgetPwd", _("Network connection error occurred. Please try again."));
		}
	});
}
function countdown(params){
	var time = params.time;
	if(time < 1){
		return;
	}
    params.msgCallback && params.msgCallback.call(params.scope || {},time);
	var intervalId = setInterval(function(){
		time--;
        params.msgCallback.call(params.scope || {},time);
		if(time === 0){
			clearInterval(intervalId);
            params.callback && params.callback.call(params.scope || {});
		}
	}, 1000);
}

