//根据type类型返回formid
function setRegestType (type) {
	var formid;
	if (type === "regest") {
		formid = "mode_regestUser";
	} else if (type === "complete") {
		formid = "mode_complete";
	} else if (type === 'completeInfo') {
		formid = "mode_complete_userInfo";
	}
	return formid;
}
//校验注册和完善信息页面手机号码、邮箱、用户名
function checkPhoneEmailUserVal(type, inputType, inputVal) {
	var params = {},
		formid = setRegestType(type);
	if (inputType === 'mobile') {
		params.opr = "checkPhone";
		params.phone = inputVal;
	} else if (inputType === 'email') {
		params.opr = "checkMail";
		params.mail = inputVal;
	} else if (inputType === 'user') {
		params.opr = "checkUserName";
		params.username = inputVal;
	}
	$.ajax({
		url: g_regUrl,
		data: params,
		type: "POST",
		success: function(json) {
			var json = json_decode(json);
			if (json.success) {
				js_alert(formid, '');
				return true;
			} else {
				//校验不通过，显示不符合的输入项信息
				dealRegestAndCompleteValidate(type, json);
				return false;
			}
		},
		error: function(o) {
			var formid;
			formid = setRegestType(type);
			js_alert(formid, o.msg || _('Network connection error occurred.'));
		}
	})
}
//提交注册或完善信息表单提交时后台返回的校验
function dealRegestAndCompleteValidate(type, json) {
	var formid;
	formid = setRegestType(type);
	js_alert(formid, json.msg);

}

//密码登录，密码登录按钮事件
function onWXscanBind() {
	var userVal = $id("wxscan_name").value,
		pwdVal = $id("wxscan_pwd").value;

	if ((userVal.length <= 0) || (pwdVal.length <= 0)) {
		js_alert("mode_wxscanAccount", _("Username or password are required."));
		return false;
	} else if (userVal.length > 95) {
		js_alert("mode_wxscanAccount", _("Username cannot exceed 95 characters."));
		return false;
	}
	js_alert("mode_wxscanAccount", '');
	var rckey = +(new Date()) + '';
	var pwd = do_encrypt_rc4(pwdVal, rckey);
	var params = {
		opr: 'pwdLogin', //smsLogin表示短信认证登录,pwdLogin表示密码认证登录
		userName: userVal,
		pwd : pwd,
		auth_tag: rckey,
		rememberPwd: $id("rememberPwd") && $id("rememberPwd").checked ? '1' : '0'
	};
	if (g_WXscanOpenID) {
		params.openid = g_WXscanOpenID;
	}
	if (g_wxscan_mobile_openid) {
		params.openid = g_wxscan_mobile_openid;
		params.controller_type = g_wxscan_mobile_bind_controller_type;
		params.ip = g_wxscan_mobile_bind_ip;
		params.controller = g_wxscan_mobile_bind_controller_id;
	}
	var btn = $id("wxscanAccount_submitBtn");
	var $btn = $(btn);
	$btn.addClass('disabled');
	btn.orgValue = btn.value;

	//成功后干啥
	function fn(o) {
		btn.disabled = false;
		$btn && $btn.removeClass('disabled');
		if (!o || !o.success) {
			js_alert("mode_wxscanAccount", o.msg);
			return;
		}
		//登录成功后启用或关闭心跳状态
		enablePop(o.pop);
		
		//取登录成功后的用户名
		var username = userVal;
		if (o.userName) {
			username = encodeURIComponent(htmlDecode(o.userName));
		}
		
		var exParams = "userName="+username+"&pwd="+pwd+"&auth_tag="+rckey;
		if (changeA()) {
			var url = window.location.href + (window.location.search != "" ? "&" : "?") + "safariid=2&" + exParams;
		    var link = document.getElementById("wxcan_link");
		    if (!link) {
		        $('body').append('<a id="wxcan_link" href="javascript:void(0);" style="display:none;position:absolute;" target="_blank"></a>');
		        link = document.getElementById("wxcan_link");
		    }
		    if (link) {
		        link.href = url;
		        link.click();
		    }
		} else {
			callWechatBrowser('WXscan', exParams);
		}
	}

	$ajax(params, "mode_wxscanAccount", function(o) {
		fn(o);
	}, btn, function() {
		$btn.removeClass('disabled');
	}, false);
}
