}

function encryptByTripleDES(message) {
    var keyHex = CryptoJS.enc.Utf8.parse('sangfor.');
    if (!message) {
        return '';
    }
    var encrypted = CryptoJS.DES.encrypt(String(message), keyHex, {
        mode: CryptoJS.mode.ECB,
        padding: CryptoJS.pad.Pkcs7
    });
    return encodeURIComponent(encrypted.ciphertext.toString());
}

// AES-CBC-128位加密
function EncryptAES(word, iv) {
	iv = CryptoJS.enc.Utf8.parse(iv);
	
	var srcs = CryptoJS.enc.Utf8.parse(word);
	// 加密模式为CBC，补码方式为ZeroPadding
	var encrypted = CryptoJS.AES.encrypt(srcs, SECOND_AUTH_AESCDC_KEY, {
		iv: iv,
		mode: CryptoJS.mode.CBC,
		padding: CryptoJS.pad.ZeroPadding
	});

	//返回base64
	return CryptoJS.enc.Base64.stringify(encrypted.ciphertext);

}

// AES-CBC-128位解密
function DecryptAES(word, iv) {
	iv = CryptoJS.enc.Utf8.parse(iv);

	var base64 = CryptoJS.enc.Base64.parse(word);
	var src = CryptoJS.enc.Base64.stringify(base64);

	// 解密模式为CBC，补码方式为ZeroPadding
	var decrypt = CryptoJS.AES.decrypt(src, SECOND_AUTH_AESCDC_KEY, {
		iv: iv,
		mode: CryptoJS.mode.CBC,
		padding: CryptoJS.pad.ZeroPadding
	});

	var decryptedStr = decrypt.toString(CryptoJS.enc.Utf8);
	return decryptedStr.toString();
}

// 二次认证相关的报错提示
function jsAlertTwoAuth(msg) {
	js_alert('mode_verifyIdentidy', msg);
}

// 二次认证密码验证校验
function authPwdValidtor() {
	var user = $id('mode_verifyIdentidy-password_name').value,
			pwd = $id('mode_verifyIdentidy-password_pwd').value;
	if ((user.length <= 0) || (pwd.length <= 0)) {
		jsAlertTwoAuth(_('Username and password are required. '));
		return false;
	} else if (user.length > 95) {
		jsAlertTwoAuth(_('Username cannot exceed 95 characters.'));
		return false;
	}
	jsAlertTwoAuth('');
	return true;
}

// 验证手机号：非空，最大20位，只能输入数字（已在html中进行校验）
function valitePhone(user) {
	if (user && !user.disabled) {
		if (user.value.length <= 0) {
			jsAlertTwoAuth(_("Mobile number is required. "));
			return false;
		} else if (user.value.length > MAX_PHONE_NUM) {
			jsAlertTwoAuth(_("Mobile number cannot exceed 20 characters."));
			return false;
		}
	}
	return true;
}

// 二次认证短信验证校验 -手机号：非空，最大20位，只能输入数字（已在html中进行校验），验证码：非空，6位数字
function valiteCodeSms() {
	// 手机号验证不通过，直接报错提示
	if (!valitePhone($id("mode_verifyIdentidy-sms_name"))) return;
	
	var pwd = $id('mode_verifyIdentidy-sms_pwd').value;
	if (pwd === '') {
		jsAlertTwoAuth(_('Verification code is required. '));
		return false;
	}
	if (pwd.length !== 6) {
		jsAlertTwoAuth( _("Verification code must be 6 digits long. "));
		return false;
	}

	jsAlertTwoAuth('');
	return true;
}

// 根据传入的tabs前往指定的认证页面
function gotwoFactorAuth(url, tabsParams) {
	var twoAuthUrl = replaceParamVal(url, 'tabs', tabsParams);
	window.location.href = twoAuthUrl;
}

// 返回首次认证，这里需要区分是否是由预览页面的二次认证返回
function backFirstAuth() {
	var isPreview = getUrlParam("ispreview");
	var isTwoAuth = getUrlParam("tabs") === 'twoAuthOpt';

	if (isPreview && isTwoAuth) {
		previewChangeSelect('showfirst');
		return;
	}
	activatePage('login')
}

// 切换预览页面下的首次认证和二次认证的下拉框的值和页面
function previewChangeSelect(type) {
	if (window.parent.topFrame) {
		window.parent.topFrame.setAuthSelect(type, PREVIEW_TYPE.pc)
		window.parent.topFrame.show(PREVIEW_TYPE.pc);
	} else {
		window.parent.parent.topFrame.setAuthSelect(type, PREVIEW_TYPE.mobile)
		window.parent.parent.topFrame.show(PREVIEW_TYPE.mobile);
	} 
}

// 替换指定传入参数的值,oUrl为链接,paramName为参数,replaceWith为新值
function  replaceParamVal (oUrl, paramName, replaceWith) {
	var re = new RegExp('(' + paramName + '=)([^&]*)', 'gi');
	return oUrl.replace(re, paramName + '=' + replaceWith);
}

// 二次认证动态码校验 校验条件：非空、只能输入6位数字
function otpValidtor(type) {
	var code = $id(AuthTypeMap[type].inputId).value;
	if(!code) {
		js_alert(AuthTypeMap[type].authId, _("Code is required. "));
		return false;
	}
	if (code.length !== 6) {
		js_alert(AuthTypeMap[type].authId, _("Code must be 6 digits long. "));
		return false;
	}
	return true;
}

// 二次认证动态码登录
function onOtpLogin(type) {
	//校验不通过直接退出
	if (!otpValidtor(type)) return;

	var authType = AuthTypeMap[type] || {};
	var params = authType.loginParams;
	params.pwd = $id(authType.inputId).value;

	// 登录时，给后台发送字段确认是否为预览页面
	params.preview = (window.top.location.search.indexOf('is_preview') !== -1);

	//参数组装好，调用通用的登录方法
	loginRequest(params, authType.authId, $id(authType.loginBtn));
}

// 打开动态码指引页面
function openAuthGuidePage() {

	// 获取【获取密钥】按钮状态（是否有权限获取）
	getBtnCode();
	activatePage('downdymanicCodeApp');
}

// 获取【获取密钥】按钮是否可点击，只有obtainKeyPermission为true才可点击
function getBtnCode() {
	$('.app_get-code').hide()
	$('.app_get-code_disable').show()
	$.ajax({
		url: g_url,
		type: "POST",
		data: {
			opr: 'getOtpSecretKeyAuthWay'
		},
		success: function(json) {
			var json = json_decode(json);
			if (json && json.success) {
				if (json.obtainKeyPermission) {
					$('.app_get-code').show()
					$('.app_get-code_disable').hide()
				}
			}
		}
	})
}

// 切换动态码指引的显示，未选中的添加透明度样式
function changeDynamicTab(tab) {
	$('#microsoftAuthenticatorApp, .microsoft-triangle-up')[tab === 'microsoft' ? 'show' : 'hide']();
	$('#googleAuthenticatorApp, .google-triangle-up')[tab === 'microsoft' ? 'hide' : 'show']();

	$('.microsoftAuthenticatorApp')[tab === 'microsoft' ? 'removeClass' : 'addClass']('opacity-class');
	$('.googleAuthenticatorApp')[tab === 'microsoft' ? 'addClass' : 'removeClass']('opacity-class');
}

// 关闭获取密钥弹窗
function closeModel() {
	$('#auth-step_second, #mode_verifyIdentidy_page').hide();
	if (currentAjax) {
		currentAjax.abort();
	}
}

// 打开获取密钥弹窗
function getCode(isOverdue, appValue) {
	$("#single-title").html(_('Get OTP Secret Key'));

	// 每次打开获取密钥弹窗，都要清空之前输入的输入框文案（为了兼容ie8，需要同时修改对应label的提示语显示）
	$("#mode_verifyIdentidy-password_name, #mode_verifyIdentidy-password_pwd, #mode_verifyIdentidy-sms_pwd, #mode_verifyIdentidy-sms_name").val('');
	$("#mode_verify-phone_label, #mode_verify-password_label, #mode_verify-name_label, #mode_verify-pwd_label").attr("style", 'opacity: 1');

	// 打开获取密钥弹窗
	activatePage(isOverdue ? 'getOverdueCode' : 'getAuthCode')
}

// 请求获取密钥弹窗内容
function initCreditSecret () {

	// 由于每次打开弹窗，认证方式都有可能变化，因此每次打开都先重置下弹窗，然后根据返回的内容再显示正确的验证方式
	resetSecretModel();

	$.ajax({
		url: g_url,
		type: "POST",
		timeout: 10 * 6 * 1000,
		data: {
			opr: 'getOtpSecretKeyAuthWay'
		},
		success: function(json) {
			var json = json_decode(json);
			if(json.backFirstAuth) {
				jsAlertTwoAuth(json.msg);
				delayExecutionFn('backFirst');
				return
			}
			if (json && json.success && json.authTab.length > 0) {
				var showCth = !json.obtainKeyPermission;
				$('#app_get-code')[showCth ? 'hide' : 'show']();
				$('#app_get-code_disable')[showCth ? 'show' : 'hide']();

				showPwdAuth(json);
				initStepMethod(json.authTab);
			}else {
				jsAlertTwoAuth(json.msg || _('Loading failed. Please contact the network administrator.'));
			}
		},
		error: function(o) {
			jsAlertTwoAuth(son.msg);
			o.backFirstAuth && delayExecutionFn('backFirst');
		}
	})
}

// type=backFirst：延时3s返回首次认证
// type=closeModle：延时3s关闭密码验证弹窗
function delayExecutionFn(type) {
	setTimeout(function() {
		type === 'backFirst' ? backFirstAuth() : closeModel();
	}, BACK_DELY_TIMEOUT);
}

// 重置弹窗内容
function resetSecretModel() {
	$('#auth-pwd-submitBtn, #secret_submitBtn').val(_('OK'));
	$('#mode_verifyIdentidy_page, #mode_verifyIdentidy .step_first').show();
	$("#sms-auth-can-bind, #sms-auth-cannot-bind, #mode_verifyIdentidy-sms, #secret_submitBtn").hide();
	$("#mode_verifyIdentidy-sms_name, #mode_verifyIdentidy-sms_pwd").attr("disabled", false);
	$("#sms-auth-no_bind").html('');
}

// 生成短信验证方式
function showPwdAuth(result) {
	var phone = '';

	// 解密后台返回的手机号码
	if (result.phone) {
		phone = DecryptAES(result.phone, result.iv) ||  ''
	}

	// 手机号码以****的形式加密
	g_user_phone = phone;
	phone = getPhoneNum(phone);

	if (result.authTab.indexOf('smsAuth') !== -1) {

		// 用户已绑定手机号-直接可以输入验证码进行验证
		if (phone) {
			$("#sms-auth-no_bind").html('Use the bound mobile number ' + phone + ' for verification');
			$("#sms-auth-no_bind").attr("style", 'color: #5C5C5C;');
			$("#sms-auth-can-bind, #secret_submitBtn").show();
			$("#mode_verifyIdentidy-sms_name").attr("disabled", true);
		} else {
			if(result.autoBind) {
				// 用户未绑定手机号，但是允许用户自动绑定手机号-可以通过输入手机号和验证码进行验证，验证成功后会自动绑定手机号
				$("#sms-auth-no_bind").html('You have not bound a mobile number for SMS verification. The number specified here will be auto bound to your account, and can be used to verify future logins.');
				$("#sms-auth-can-bind, #mode_verifyIdentidy-sms, #secret_submitBtn").show();
				$("#sms-auth-no_bind").attr("style", 'color: #D94B4B;');
			} else {
				// 用户未绑定手机号，且不允许自动绑定，直接提示请联系管理员
				$("#mode_verifyIdentidy-sms_name, #mode_verifyIdentidy-sms_pwd").attr("disabled", true);
				$("#sms-auth-cannot-bind").show();
				$("#secret_submitBtn").hide();
			}
		}
	}
}

/**
 * 若用户已绑定手机号，对手机号进行加密，具体加密规则为：x位->显示
 * 1位手机号，直接显示(不太可能出现这个现象，兜底)
 * 2~5位手机号，只显示最后一位数字，其他用*代替(2位->*1、3位->**2、4位->***3、5位->****4)
 * 超过5位手机号，中间4位替换成****，
 * * 奇数位：7位->1****67、9位->12****789、11位->123****8901
 * * 偶数位：6位->1****6、8位->12****78、10位->123****890
 */
function getPhoneNum(phone) {
	if (phone.length > 4) {
		var halfPhone = (phone.length - 4)/2;
		var reg =new RegExp("(\\d{" + Math.floor(halfPhone) + "})\\d{4}(\\d{" + Math.ceil(halfPhone) + "})")
		phone = phone.replace(reg, '$1****$2')
	} else {
		phone = new Array(phone.length).join('*') + phone.substring(phone.length - 1, phone.length)
	}
	return phone;
}

/** 展示切换认证方式 */
function initStepMethod(authTab) {
	$('#mode_verifyIdentidy .sms-auth, #mode_verifyIdentidy .pwd-auth, #mode_verifyIdentidy .smsAuth, #mode_verifyIdentidy .pwdAuth').hide();

	var sorts = authTab;

	var dividTab = '#mode_verifyIdentidy .step_tabs .';
	for (var i = 0; i < sorts.length; i++) {
		(function() {
			var temp = sorts[i];
			var sortItem = $(dividTab + temp);
			$('#mode_verifyIdentidy .' + sorts[i]).show();
			sortItem.click(function() {
				js_alert("mode_verifyIdentidy", '');
				for(var j = 0; j < sorts.length; j++) {
						$('#mode_verifyIdentidy .' + creditSecretConst[sorts[j]])[temp === sorts[j] ? 'show' : 'hide']();  //对应内容显示

					//更新tab状态
					if (temp === sorts[j]) {
						sortItem.addClass('step_tabs_item_acitve');
					} else {
						$(dividTab + sorts[j]).removeClass('step_tabs_item_acitve');
					}
				}
			});
		})(i)
	}

	// 默认选择第一个
	$(dividTab + sorts[0]).trigger('click');
}

function getRamNumber(num) {
	var result = '';
	for(var i = 0; i < num; i++) {
	result+=Math.floor(Math.random()*num).toString(RANDOM_NUM);//获取0-15并通过toString转16进制
	}
	 
	//默认字母小写，手动转大写
	return result.toUpperCase();//另toLowerCase()转小写
}	

// 二次认证动态码认证，密码验证登录
function onAuthPwdLogin() {
	if(!authPwdValidtor()) return false;
	var iv = getRamNumber(RANDOM_NUM);
	var params = {
		opr: 'otpPwdAuth',
		userName: $id("mode_verifyIdentidy-password_name").value,
		pwd: EncryptAES($id("mode_verifyIdentidy-password_pwd").value, iv),
		iv: iv
	};
	var btn = $id("auth-pwd-submitBtn");
	verifyOtpCode(btn, params);
}

// 获取二次认证动态码短信认证的验证码
function onGetOtpSmsCode() {
	// 手机号验证不通过，直接报错提示
	if (!valitePhone($id("mode_verifyIdentidy-sms_name"))) return;
	
	var iv = getRamNumber(RANDOM_NUM);
	var userName = g_user_phone ? g_user_phone : $id('mode_verifyIdentidy-sms_name').value;
	var params = {
		opr: 'getOtpSmsCode',
		userName: EncryptAES(userName, iv),
		iv: iv
	}
	cookie.set('optSmsCode', userName, g_remberTime);

	// 获取短信验证码
	getSmsCodeRequest(params, 'mode_verifyIdentidy', $id('mode_verifyIdentidy-sms_getCodeBtn'), function(o) {
		o.backSecretVerification && delayExecutionFn('closeModel');
	})
}

// 发送短信验证请求
function getCodeSms () {
	if (!valiteCodeSms()) return false;
	var iv = getRamNumber(RANDOM_NUM);
	var params = {
		opr: 'verifyOtpSmsCode',
		userName: EncryptAES(g_user_phone ? g_user_phone : $id('mode_verifyIdentidy-sms_name').value, iv),
		pwd: $id("mode_verifyIdentidy-sms_pwd").value,
		iv: iv
	};
	var btn = $id("secret_submitBtn");
	verifyOtpCode(btn, params)
}

// 校验短信验证和密码验证
function verifyOtpCode (btn, params) {
	btn.orgValue = btn.value
	btn.value = _('Verifying')
	btn.disabled = true;
	var $btn = $(btn);

	$ajax(params, 'mode_verifyIdentidy', function(o) {
		btn.disabled = false;
		if (!o.success) {
		  btn.value = btn.orgValue;
			jsAlertTwoAuth(o.msg);
			o.backSecretVerification && delayExecutionFn('closeModel');
			return;
		}
		btn.value = _('Verified')
		$('#auth-step_first, #step_tabs_all').hide();
		$('#auth-step_second').show();
		var url = o.secretKey || '';
		if(url && o.iv) {

			// 获取到加密的二维码信息后，先解密出密钥信息，再进行二维码的显示
			var target = url.match(REG_SERECT_VALID);
			g_target = DecryptAES(target && target[1] || '', o.iv);
			var newUrl = replaceParamVal(url, 'secret', g_target)

			$("#sms-auth_qrcodeImg").html(create_qrcode(newUrl, newUrl.length <= 400 ? "12" : "0", "L"));
			$("#sms-auth_qrcodeText").html(g_target);
			
			getBtnCode();
		} else {
			$("#sms-auth_qrcodeText").html(_('Failed to get the barcode.'));
		}
	}, btn, function() {
		btn.disabled = false;
		btn.value = btn.orgValue;
		$btn && $btn.removeClass('disabled');
	});
}

// 复制密钥
function copyText () {
	if (window.clipboardData) {
		// 清除原有剪切板的数据
		window.clipboardData.clearData();
		// 将内容复制到剪切板
		window.clipboardData.setData("Text", g_target);
		// 其它浏览器,
		SF.showMsg(_("复制成功"));
	} else {
		if (!document.queryCommandSupported || !document.queryCommandSupported("copy")) {
			SF.showErr(_('该浏览器不支持复制文本功能，请手动复制或者更换浏览器后重试'));
		}
			var dom = document.body,
					textArea = document.createElement("textArea");
			dom.appendChild(textArea);
			textArea.style.position = "absolute";
			textArea.style.left = "-9999px";
			textArea.style.top = "-1000px";
			textArea.value = g_target

			// 防止ios设备点击复制选中输入框时，键盘弹出在隐藏导致的页面抖动，隐私直接禁用输入框
			textArea.setAttribute('readonly', 'readonly')
			textArea.select();
			document.execCommand("Copy");
			dom.removeChild(textArea);
			$("#auth-login_success_copy").show();
			$("#auth-login_success_copy").delay(3000).hide(300);
	}
}