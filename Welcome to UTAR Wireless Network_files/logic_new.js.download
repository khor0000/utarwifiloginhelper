//初始化修改密码强度变量(不用改动)
function initPstrength() {
	var safariid = getUrlParam('safariid');
	safariid = safariid.toString();

	if (safariid !== "1") {
		$.ajax({
			url: "/passwordstrength",
			type: "GET",
			success: function(resp) {
				var json = json_decode(resp);
				if (json) {
					g_pstrength = json;
				} else {
					//alert(_("Password does not meet strength requirement."));
				}
			},
			error: function(o) {
				//alert(_("Failed to load password strength due to network error."));
			}
		})
	}
}

