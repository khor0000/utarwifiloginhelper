//会议室二维码pc端提交数据
function submitMtQrcodeInfo() {
	var jsonData = {};
	var type = 'mtqrcode';
	var infoItem = g_infoback_mtqrcode;
	var mobileReg = /^\d{1,20}$/;
	var domReg = /^[^`~!#$%^&*()+=\\|{};:"',/<>?]*$/;
	var mailReg = /^(\w-*\.*)+@(\w-?)+(\.\w{2,})+$/;
	var formid = 'mode_mtqrcode_info';
	for (var i = 0; i < infoItem.length; i++) {
		var id = infoItem[i].id;
		var name = infoItem[i].name;
		var getAttrId = type + '_' + id + '_attr';
		var attrValue = $id(getAttrId);
		attrValue = attrValue && attrValue.value || '';
		if (id === 'phone') {
			jsonData["vcode"] = $id("mtqrcode_sms_code") && $id("mtqrcode_sms_code").value;
		}
		//提交之前进行校验
		if (infoItem[i].request) {
			if (id === 'phone') {
				if (!mobileReg.test(attrValue)) {
					js_alert(formid, _("Separator of mobile phone numbers is invalid."));
					return;
				}
			}
			else if (id === 'mail') {
				if (!domReg.test(attrValue)) {
			        js_alert(formid, _('It cannot contain any of the following special characters: ^[^`~!#$%^&*()+=\\|{};:\"\',/<>?]*$'));
			        return;
			    }
			    if (!mailReg.test(attrValue)) {
			    	js_alert(formid, _('It is not a valid email address.'));
			        return;
			    }
			    if (attrValue.length > 63) {
			    	js_alert(formid, _('It cannot exceed 63 characters.'));
			    	return;
			    }
			} else if (attrValue === '') {
				js_alert(formid, name + _(" is required."));
				return false;
			} else {
				if (attrValue.length > 95) {
					js_alert(formid, name + _(" cannot exceed 95 characters."));
					return;
				}
                if (!domReg.test(attrValue)) {getloginSuccessJumpURL
                    js_alert(formid, name + _('It cannot contain any of the following special characters: ^[^`~!#$%^&*()+=\\|{};:\"\',/<>?]*$'));
                    return;
                }
			}
		}
		jsonData[id] = attrValue;
	}

	var r = randomNum(0, 99),
		t = (new Date()).getTime(),
		c = r * t;
	var qcid = $("#mtqrcode_id").val();
	var params = jsonData;
	params.r = r;
	params.t = t;
	params.c = c;
	params.ip = getUrlParam('ip');
	params.qcid = qcid;
	params.controller_type = getUrlParam('controller_type');
	params._ID_ = getUrlParam('_ID_');

	$.ajax({
		url: '/ac_portal/mtqrcode.html',
		type: 'POST',
		data: params,
		success: function(rep) {
			var json = rep; //json_decode(rep);

			if (json.success) {
				httpscert_jump(getloginSuccessJumpURL(json.url, json.username));
			} else {
				js_alert("mode_mtqrcode_info", json.msg || _('Network connection error occurred.'));
			}

		},
		error: function(rep) {
			js_alert("mode_mtqrcode_info", _('Network connection error occurred.'));
		}
	});
}
//访客二维码提交信息项
function submitQrcodeInfoItem(type) {
	var infoItem = g_infoback_qrcode || [];
	var jsonData = {};
	var url = '/ac_portal/qr_uinfo.html';
	var mobileReg = /^\d{1,20}$/;
	var domReg = /^[^`~!#$%^&*()+=\\|{};:"',/<>?]*$/;
	var mailReg = /^(\w-*\.*)+@(\w-?)+(\.\w{2,})+$/;
	var formid = 'mode_qrcode_info';
	//元素失去焦点时已进行过校验，直接获取元素的值进行提交即可
	for (var i = 0; i < infoItem.length; i++) {
		var id = infoItem[i].id;
		var name = infoItem[i].name;
		var getAttrId = type + '_' + id + '_attr';
		var attrValue = $id(getAttrId);
		attrValue = attrValue && attrValue.value || '';
		//提交之前进行校验
		if (infoItem[i].request) {
			if (id === 'phone') {
				if (!mobileReg.test(attrValue)) {
					js_alert(formid, _("Separator of mobile phone numbers is invalid."));
					return;
				}
			}
			else if (id === 'mail') {
				if (!domReg.test(attrValue)) {
			        js_alert(formid, _('It cannot contain any of the following special characters: ^[^`~!#$%^&*()+=\\|{};:\"\',/<>?]*$'));
			        return;
			    }
			    if (!mailReg.test(attrValue)) {
			    	js_alert(formid, _('It is not a valid email address.'));
			        return;
			    }
			    if (attrValue.length > 63) {
			    	js_alert(formid, _('It cannot exceed 63 characters.'));
			    	return;
			    }
			} else if (attrValue === '') {
				js_alert(formid, name + _(" is required."));
				return false;
			} else {
				if (attrValue.length > 95) {
					js_alert(formid, name + _(" cannot exceed 95 characters."));
					return;
				}
                if (!domReg.test(attrValue)) {
                    js_alert(formid, name + _('It cannot contain any of the following special characters: ^[^`~!#$%^&*()+=\\|{};:\"\',/<>?]*$'));
                    return;
                }
			}
		}
		jsonData[id] = attrValue;
	}
    $("#qrcode_btn").prop('disabled', true);
	var params = jsonData;
	jsonData.ip = getUrlParam("ip");
	jsonData.r = getUrlParam("r");
	jsonData.t = getUrlParam("t");
	jsonData.vlanid = getUrlParam("vlanid");
	jsonData.c = getUrlParam("c");
	jsonData.controller_type = getUrlParam("controller_type");
	jsonData._ID_ = getUrlParam("_ID_");

	function error(msg) {
		var formid = "mode_qrcode_info";
		js_alert(formid, msg);
	}
	$.ajax({
		url: url,
		data: params,
		type: "POST",
		success: function(json) {
    		$("#qrcode_btn").prop('disabled', false);
			// var json = json_decode(resp);
			if (json && json.success) {
				successFn(json);
			} else {
				// successFn();
				error((json && json.msg) || _("Login failed. Please contact the network administrator."));
			}
		},
		error: function(o) {
    		$("#qrcode_btn").prop('disabled', false);
			// successFn();
			error(_("Network connection error occurred."));
		}
	});

	function successFn(json) {
		changeQrcodeStep(1);
		//TODO
		//activatePage("loginSuccess");
	}
}
//用户完善信息页面点击已经拥有账号的页面提交用户名
function onSubmitCompleteUser() {
	var username = $("#complete_user_username").val();
	if (!username) {
		js_alert("mode_complete_user", _("Please specify username first."));
		return;
	}
	var params = {
		opr: 'query',
		policy: getUrlParam('policy', true),
		policy_type: getUrlParam('policy_type'),
		username: username
	};
	var btn = $id('completeUser_submitBtn'),
		fn = function() {
			if (btn) {
				btn.value = btn.orgValue;
				btn.disabled = false;
			}
		};
	if (btn) {
		btn.orgValue = btn.value;
		btn.disabled = true;
		btn.value = _('Please wait...');
	}
	$.ajax({
		url: g_url,
		data: params,
		type: "POST",
		success: function(json) {
			json = json_decode(json);
			if (json.success) {

				dealInfoItem(json, 'completeInfo');
				activatePage('completeUserInfo', username);
			} else {
				js_alert("mode_complete_user", json.msg || _("Network connection error occurred."));
			}
			fn();
		},
		error: function(o) {
			fn();
			// error(_("网络异常"));
		}
	})

}
//用户注册，确定按钮事件，提交注册信息
function onRegestUser(type, idStr) {
	// if (!regestAndCompleteValidator(type)) return;
	var formInfo = g_infoback,
	    isLocal = g_infoback.is_local,
		jsonData = {},
		groupListID = '#' + type + 'GroupList',
		attrs = formInfo.attr_list,
		hasBuildPhone = false, //是否有内置的手机号的标志
		hasBuildEmail = false, //是否有内置的邮箱的标志
		formid,
        nameReg = /[,/]/,
		remainAttrs = []; //用来保存除特殊属性之外的其他属性
	if (formInfo.group_enable) {
		jsonData.group = $(groupListID).val();
	}
	var domReg = /^[^`~!#$%^&*()+=\\|{};:"',/<>?]*$/;

	if (type === 'regest') {
		var rckey = +(new Date()) + '';
		var pwd = do_encrypt_rc4($id("regest_password").value, rckey);

		jsonData.username = $("#regest_username").val();
		jsonData.password = pwd;
		jsonData.auth_tag = rckey;
		formid = "mode_regestUser";

		if (!validateRegestPasswordStrength(formid)) {
			return;
		}
	} else if (type === 'complete') {
		jsonData.username = $("#complete_username").val();
		formid = "mode_complete";
	} else if (type === 'completeInfo') {
		jsonData.username = $("#completeInfo_username_default").val();
		formid = "mode_complete_userInfo";
	}
    if (nameReg.test(jsonData.username)) {
        js_alert(formid, _('Username cannot contain any of the following characters: ,/'));
        return;
    }
    if (jsonData.username.length > 95) {
    	js_alert(formid, _('Username cannot exceed 95 characters.'));
	return;
    }
	for (var i = 0; i < attrs.length; i++) {
		//先将内置的手机号码和邮箱账号的提取出来
		if (attrs[i].build_in && attrs[i].attr === 'phone') {
			hasBuildPhone = true;
		} else if (attrs[i].build_in && attrs[i].attr === 'mail') {
			hasBuildEmail = true;
		} else {
			//剩下的属性
			remainAttrs.push(attrs[i]);
		}
	}
	//获取手机、验证码
	if (hasBuildPhone) {
		jsonData.phone = $('#' + type + '_phone_attr').val();
		if (formInfo.bind_mobile) {
			jsonData.smsCode = $('#' + type + '_sms_code').val();
		}

		var mobileReg = /^\d{1,20}$/;
		if (!mobileReg.test(jsonData.phone)) {
			js_alert(formid, _("Separator of mobile phone numbers is invalid."));
			return;
		}
	}
	//获取邮箱、验证码
	if (hasBuildEmail) {
		jsonData.mail = $('#' + type + '_mail_attr').val();
		if (typeof($('#' + type + 'DomainList').val()) != 'undefined') {
			jsonData.mail = jsonData.mail + $('#' + type + 'DomainList').val();
			if (!domReg.test(jsonData.mail)) {
		        js_alert(formid, _('It cannot contain any of the following characters: ^[^`~!#$%^&*()+=\\|{};:\"\',/<>?]*$'));
		        return;
		    }
		    var mailReg = /^(\w-*\.*)+@(\w-?)+(\.\w{2,})+$/;
		    if (!mailReg.test(jsonData.mail)) {
		    	js_alert(formid, _('It is not a valid email address.'));
		        return;
		    }
		    if (jsonData.mail.length > 63) {
		    	js_alert(formid, _('It cannot exceed 63 characters.'));
		    	return;
		    }
		}
		if (formInfo.bind_email) {
			jsonData.mailCode = $('#' + type + '_mail_code').val();
		}
	}


	//对剩下属性组装数据
	for (var j = 0; j < remainAttrs.length; j++) {
		var remainAtt = remainAttrs[j].id;
		jsonData[remainAtt] = $('#' + type + '_' + remainAtt + '_attr').val();
		//提交之前进行校验
		if (remainAttrs[j].required) {
			if (jsonData[remainAtt] === '') {
				js_alert(formid, _(remainAttrs[j].attr + " is required."));
				return;
			} else {
				if (!domReg.test(jsonData[remainAtt])) {
			        js_alert(formid, _(remainAttrs[j].attr + ' cannot contain any of the following special characters: ^[^`~!#$%^&*()+=\\|{};:\"\',/<>?]*$'));
			        return;
			    }
			    if (jsonData[remainAtt].length > 95) {
			    	js_alert(formid, _(remainAttrs[j].attr + ' cannot exceed 95 characters.'));
				return;
			    }
			}
		}
	}

	// 根据元素判断是否存在验证码
	var $codeElement = $('#regest_captcha_code');
	var CHECKCODE_COUNT = 4; //验证码长度
	var noNeedCode = ['completeInfo'].indexOf(type) > -1
	if (!noNeedCode && $codeElement[0]) {

		// 验证码字段
		jsonData.captcha_code = $codeElement.val();

		// 验证码默认字段
		jsonData.captcha_type = 'register';

		if (!jsonData.captcha_code) {
			js_alert(formid, 'Please enter the characters in the image.');
			return;
		} else {

			//验证码的长度，必须为4位
			if(jsonData.captcha_code.length !== CHECKCODE_COUNT) {
				js_alert(formid, 'Please enter 4 characters.');
				return;
			}

			//验证码不能包含特殊字符
			if (!domReg.test(jsonData.captcha_code)) {
				js_alert(formid, "Code cannot contain any of the following special characters: `~!#$%^&*()+=\|{}[];:\"\',\/<>?\r\n");
				return;
			}

		}
	}
	
	//发送注册信息或完善信息请求
	regestAndCompleteRequest(type, jsonData, isLocal, idStr);
}
//注册和完善信息页面请求
function regestAndCompleteRequest(type, jsonData, isLocal, idStr) {
	var params = jsonData,
		formid;
	params.opr = 'register';
	if (isLocal) {
		params.opr = "perfect";
	}
	formid = setRegestType(type);

	var btn = $id(idStr),
		fn = function() {
			if (btn) {
				btn.value = btn.orgValue;
				btn.disabled = false;
			}
		};
	if (btn) {
		btn.orgValue = btn.value;
		btn.disabled = true;
		btn.value = _('Please wait...');
	}
	$.ajax({
		url: g_regUrl,
		// data: JSON.stringify(params),
		data: params,
		// datatype: 'jsonp',
		type: "POST",
		// contentType: false,
		//       processData: false,
		success: function(json) {
			// json = json_decode(json);
			if (json.success) {

				if (type === "regest") {
					if (json.freeaudit) {
						activatePage("regAndComSuccess");
					} else {
						activatePage("regAndComAudit");
                        var dot1x = getUrlParam('dot1x');
                        if(dot1x === '1' || dot1x === '0'){
                            $('.reg-and-com-audit .login_head span').html('Your information is submitted. Please wait for the administrator to approve your request. An account that has not passed the audit is invalid and cannot be authenticated successfully.');
                        }

					}
				} else {
					var locationUrl = json.location;
					if (locationUrl !== '') {
						// var jump_url = getUrlParam('url');
						locationUrl = decodeURIComponent(locationUrl);
						location.href = locationUrl;
					} else {
						if (type === 'complete') {
							js_alert("mode_complete", json.msg || _("Sign up failed."));
						} else{
							js_alert("mode_complete_userInfo", json.msg || _('Failed to find this.'));
						}
					}
				}
			} else {
				if (type === "regest" || type === 'complete') {
					updateCheckcodeImg();
				}
				js_alert(formid, json.msg || _("Network connection error occurred."));
			}
			fn();
		},
		error: function(o) {
			fn();
			// error(_("网络异常"));
		}
	});
}
//获取验证码，点击获取验证码按钮事件
function onGetSmsCode(type) {
    var checked;
	if (!getSmsCodeValidtor(type)) return;
	if(type === 'sms'){
		//短信认证
        checked = $id("sms_disclaimer")? $id("sms_disclaimer").checked : true;
	}else {
		//短信快捷认证
        checked = $id("sms_fast_disclaimer") ? $id("sms_fast_disclaimer").checked : true;
	}
	if (window.g_hasDisclaimer && !checked) {
		setSmsTips(type, _("Please read and accept the Terms of Use."));
		return false;
	}
	var params = {
		opr: 'getSmsCode',
		userName: type === "fastmobile" ? $id("mobilefast_name").value : $id("sms_name").value
	};
	if (type === 'fastmobile') {
		cookie.set("fastPhoneNumber", $id("mobilefast_name").value, g_remberTime);
		params.quickLogin = 1;
		getSmsCodeRequest(params, "mode_mobile", $id("mobilefast_getCodeBtn"));
	} else {
		cookie.set("phoneNumber", $id("sms_name").value, g_remberTime);
		params.quickLogin = 0;
		getSmsCodeRequest(params, "mode_sms", $id("sms_getCodeBtn"));
	}
}

//注册页面获取手机验证码和邮箱验证码
//type为regest代表注册页面;type为complete为完善信息页面
//attr: mobile，获取手机验证码;attr:email，获取邮箱验证码
function onGetRegestCode(type, attr) {
	var regestPhone,
		regestMail,
		codeBtnID,
		formid;
	if (type === 'regest') {
		formid = "mode_regestUser";
		regestPhone = $id("regest_phone_attr") && $id("regest_phone_attr").value;
		regestMail = $id("regest_mail_attr") && $id("regest_mail_attr").value;
		if ($id("regest_phone_attr")) {
			cookie.set("regPhoneNumber", $id("regest_phone_attr").value, g_remberTime);
		}
		if ($id("regest_mail_attr")) {
			cookie.set("regMail", $id("regest_mail_attr").value, g_remberTime);
		}
	} else if (type === 'complete') {
		formid = "mode_complete";
		regestPhone = $id("complete_phone_attr") && $id("complete_phone_attr").value;
		regestMail = $id("complete_mail_attr") && $id("complete_mail_attr").value;
		if ($id("complete_phone_attr")) {
			cookie.set("comPhoneNumber", $id("complete_phone_attr").value, g_remberTime);
		}
		if ($id("complete_mail_attr")) {
			cookie.set("comMail", $id("complete_mail_attr").value, g_remberTime);
		}
	} else if (type === 'completeInfo') {
		formid = "mode_complete_userInfo";
		regestPhone = $id("completeInfo_phone_attr") && $id("completeInfo_phone_attr").value;
		regestMail = $id("completeInfo_mail_attr") && $id("completeInfo_mail_attr").value;
		if ($id("completeInfo_phone_attr")) {
			cookie.set("comInfoPhoneNumber", $id("complete_phone_attr").value, g_remberTime);
		}
		if ($id("completeInfo_mail_attr")) {
			cookie.set("comInfoMail", $id("complete_mail_attr").value, g_remberTime);
		}
	}

	if (typeof($('#' + type + 'DomainList').val()) != 'undefined') {
		regestMail = regestMail + $('#' + type + 'DomainList').val();
	}

	var params = {};
	if (attr === 'phone') {
		params.opr = 'getSmsCode';
		params.phone = regestPhone;
		codeBtnID = type + '_phone_attr_getSmsCodeBtn';
		if (regestPhone === "") {
			js_alert(formid, _("Mobile phone number is required."));
			return;
		}
	} else {
		params.opr = 'getMailCode';
		params.mail = regestMail;
		codeBtnID = type + '_mail_attr_getEmailCodeBtn';
		if (regestMail === "") {
			js_alert(formid, _("Email address is required."));
			return;
		}
	}

	//不改变原短信登录验证码的获取机制，新的注册页面、终端注册页面以及终端注册完善信息页面验证码的获取统一使用这个
	function getCodeSuccessFn(json) {
		if (type === 'regest') {
			afterGetAllCodeState(json, params, 'mode_regestUser', $id(codeBtnID), 60, type, attr);
		} else if (type === 'complete') {
			afterGetAllCodeState(json, params, 'mode_complete', $id(codeBtnID), 60, type, attr);
		} else if (type === 'completeInfo') {
			afterGetAllCodeState(json, params, 'mode_complete_userInfo', $id(codeBtnID), 60, type, attr);
		}
	}
	$.ajax({
		url: g_regUrl,
		data: params,
		type: "POST",
		success: function(resp) {
			var json = json_decode(resp);
			if (json) {
				getCodeSuccessFn(json);
			} else {
				error(json.msg || _("Login failed. Please contact the network administrator."));
			}
		},
		error: function(o) {
			// getCodeSuccessFn(o);
			error(_("Network connection error occurred."));
		}
	})
}
//短信登录，点击短信登录按钮事件
function onSmsLogin(type) {
	if (!smsValidtor(type)) return;
	var params = {
		opr: 'smsLogin',
		userName: $id("sms_name").value,
		pwd: $id("sms_pwd").value,
		rememberPwd: $id("rememberSms").checked ? '1' : '0',
		quickLogin: 0

	};
	if (type === "fastmobile") {
		var mSms = $id("rememberMobileSms"),
			mName = $id("mobilefast_name"),
			mPas = $id("mobilefast_pwd");
		params = {
			opr: 'smsLogin',
			userName: mName && mName.value,
			pwd: mPas && mPas.value,
			rememberPwd: (mSms && mSms.checked) ? '1' : '0',
			quickLogin: 1
		}
		if (g_WXscanOpenID) {
			params.openid = g_WXscanOpenID;
		}
	}
	if (type === "fastmobile") {
		loginRequest(params, "mode_mobile", $id("freeauth_submitBtn"));
	} else {
		loginRequest(params, "mode_sms", $id("sms_submitBtn"));
	}
}

//获取url参数(即url中的?url_param=content)
function getParamFromUrl(name) {
	var reg = new RegExp("(^|&)" + name + "=([^&]*)(&|$)", "i"),
		r = window.location.search.substr(1).match(reg);
	return r != null ? decodeURIComponent(r[2].replace(/\+/g, " ")) : null;
}

// 在登录后跳转前加入判断是否要跳到证书检测页面
function httpscert_jump(url) {
	var vlanid = getParamFromUrl("vlanid");

	$.ajax({
		type: "POST",
		url: "/httpscert/handler_checkjump",
		timeout: 3000,
		data: {
			vlanid: vlanid
		},
		success: function(response) {
			if (response == "1") {
				var href = "/httpscert/httpscert.html?vlanid=" + vlanid + "&url=" + encodeURIComponent(url);
                openHref(href);
			} else {
				openHref(url);
				//location.replace(url);
                /*setTimeout(function() {
					location.reload();
				}, 600);*/
			}
		},
		error: function(XMLHttpRequest, textStatus, errorThrown) {
			location.href = url;
		}
	});
}
//跳转到注销页面（含证书检测判断）
function httpscert_jump_logout(username, pop) {
	var vlanid = getParamFromUrl("vlanid");

	var url = window.location.href;

	// 去掉url参数中的pop、type、username参数
	var pattern_arr = ["&pop=", "?pop=", "&type=", "?type=", "&username=", "?username="];
	for (var i = 0; i < pattern_arr.length; i++) {
		var pattern = pattern_arr[i];
		var pos1 = url.indexOf(pattern);
		if (pos1 != -1) {
			var pos2 = url.indexOf("&", pos1 + pattern.length);
			if (pos2 != -1) {
				url = url.substr(0, pos1) + url.substr(pos2);
			} else {
				url = url.substr(0, pos1);
			}
		}
	}
	// 加入pop、type、username参数
	pop = pop ? "1" : "0";
	if (url.indexOf('?') != -1) {
		url = url + "&pop=" + pop + "&type=logout&username=" + encodeURIComponent(username);
	} else {
		url = url + "?pop=" + pop + "&type=logout&username=" + encodeURIComponent(username);
	}

	// 先停止心跳机制
	g_queryEffect = false;

	$.ajax({
		type: "POST",
		url: "/httpscert/handler_checkjump",
		timeout: 3000,
		data: {
			vlanid: vlanid
		},
		success: function(response) {
			if (response == "1") {
				location.href = "/httpscert/httpscert.html?vlanid=" + vlanid + "&url=" + encodeURIComponent(url);
			} else {
				// activatePage('logout', username);
				location.href = url; // 为触发ios的网络监测,使wifi的"取消"变为"完成"
				setTimeout(function() {
					location.reload();
				}, 200);
				g_queryEffect = true; //恢复心跳机制
			}
		},
		error: function(XMLHttpRequest, textStatus, errorThrown) {
			activatePage('logout', username);
			g_queryEffect = true; //恢复心跳机制
		}
	});
}

function getloginSuccessJumpURL (url, userName) {
	if (typeof url !== 'string') {
		url = '';
	}
	if (!userName) {
		userName = getUrlParam('username');
	}
	var url_path = url;
	var index = url_path.indexOf('?');
	if (index > 0) {
		url_path = url_path.substring(0, index);
	}
	var reg = RegExp(
		"^http://www\.airport\.us/" +
		"\|^http://www\.thinkdifferent\.us/" +
		"\|^http://captive\.apple\.com/" +
		"\|^http://www\.appleiphonecell\.com/" +
		"\|^http://www\.ibook\.info/" +
		"\|^http://www\.itools\.info/" +
		"\|^http://www\.gstatic\.com/generate_204" +
		"\|^http://clients[0-9]\.google\.com/generate_204",
		"i");
	if (!url || reg.test(url) || url_path.indexOf('generate_204') !== -1) {
		url = window.location.href;
		if (url.indexOf("&type=logout&username=") < 0) {
			url = url + "&type=logout&username=" + encodeURIComponent(userName);
		}
	}


    if(url.indexOf('type=logout') > -1) {
        url = url +'&'+ location.search.slice(1);
    }


	return url;
}

//免责声明的登录
function onDisclaimerLogin() {
	//成功后干啥
	function fn(o) {
		btn.disabled = false;
		var formid = "mode_disclaimer";
		btn.value = btn.orgValue;
		if (!o.success) {
			js_alert(formid, o.msg);
			return;
		}

		var action = o.action,
			interval;
		switch (action) {
			case "location":
				btn.disabled = true;

				httpscert_jump(getloginSuccessJumpURL(o.location, o.userName));
				break;
		}
		//登录成功后启用或关闭心跳状态
		enablePop(o.pop);
	}

	var checked = $id("dis_disclaimer") ? $id("dis_disclaimer").checked : false,
		btn = $id("dis_submitBtn");
	if (window.g_hasDisclaimer && !checked) {
		js_alert("mode_disclaimer", _((_("Please read and accept the Terms of Use."))));
		return false;
	}
	btn.orgValue = btn.value;
	btn.value = _("Please wait...");
	btn.disabled = true;
	$ajax({
		opr: 'noAuthlogin'
	}, "mode_disclaimer", fn, btn);
}

//免认证登录
function onFreeauthLogin() {
	//成功后干啥
	function fn(o) {
		btn.disabled = false;
		var formid = "mode_freeauth";
		btn.value = btn.orgValue;
		if (!o.success) {
			js_alert(formid, o.msg);
			return;
		}

		var action = o.action,
			interval;
		switch (action) {
			case "location":
				btn.disabled = true;

				httpscert_jump(getloginSuccessJumpURL(o.location, o.userName));
				break;
			case "logout":
				httpscert_jump_logout(o.userName, o.pop);
				break;
		}
		//登录成功后启用或关闭心跳状态
		enablePop(o.pop);
	}

	var checked = $id("freeauth_disclaimer") ? $id("freeauth_disclaimer").checked : true,
		btn = $id("freeauth_submitBtn");
	if (window.g_hasDisclaimer && !checked) {
		js_alert("mode_freeauth", _((_("Please read and accept the Terms of Use."))));
		return false;
	}
	btn.orgValue = btn.value;
	btn.value = _("Please wait...");
	btn.disabled = true;
	$ajax({
		opr: 'freeauth'
	}, "mode_freeauth", fn, btn);
}

function onLogout() {
	logoutRequest({
		opr: 'logout'
	}, 'mode_logout', $id('logout_submitBtn'))
}



//通用ajax请求，会转成json参数给到successFn
function $ajax(params, formid, successFn, btn, failFn, async) {
	function error(msg) {
		if (btn) {
			btn.disabled = false;
			btn.value = btn.orgValue;
		}
		js_alert(formid, msg);
	}
	currentAjax = $.ajax({
		url: g_url,
		data: params,
		type: "POST",
		async: async === false ? false : true,
		success: function(resp) {
			var json = json_decode(resp);
			if (json) {
					// 二次认证请求后判断是否会返回首次认证
			if(json.backFirstAuth) {
				js_alert(formid, json.msg);
				delayExecutionFn('backFirst');
			}
				successFn(json);
			} else {
				if (typeof failFn === 'function') {
					failFn(json);
				}
				error(_("Login failed. Please contact the network administrator."));
			}
		},
		error: function(o) {
			if (typeof failFn === 'function') {
				failFn(o);
			}
			error(_("Network connection error occurred."));
			if(o && o.backFirstAuth) {
				delayExecutionFn('backFirst');
				return;
			}
		}
	})
}

//通用登录请求
function loginRequest(params, formid, btn) {
	if (!btn) {
		return;
	}
	var $btn = $(btn);

	//成功后干啥
	function fn(o, isThird) {
		btn.disabled = false;
		btn.value = btn.orgValue;
		$btn && $btn.removeClass('disabled');
		if (!o.success) {
			if (o.keyExpired) {
				js_alert(AuthTypeMap['twoAuthOtp'].authId, _("Code has expired. "), true, '<span class="sim-link" onclick="getCode(true)">' + _('Get Code Again') + '</span>');

				// 为了防止xss攻击，提示的文案被格式化，这里重新更新提示的title
				$("#two-auth-mode_dynamicCode .login_box_msg").find("dd").attr('title', _('Code has expired. Please get code again.'));
				return;
			}

			if (formid === "mode_password_wx")
			{
				activateTab('pwd');
				formid = "mode_password";
			}
			
			js_alert(formid, o.msg);
			return;
		}

		//发送第三方的条件
		if (o.forms && isThird !== false) {
			sendThird(o, fn);
			return;
		}

		// 是否需要二次认证，跳转到二次认证登录页面
		if (o.needSecondAuth) {
			var url = window.location.href;
			// 预览页面切换二次认证时，需要同时切换右上角下拉框
			getUrlParam("ispreview") && previewChangeSelect('showsecond');
			gotwoFactorAuth(url, 'twoAuthOpt');
			activateTab('twoAuthOpt');
			return;
		}

		//做下特殊处理，登录成功后应该恢复注册页面、完善信息页面、短信快捷登录页面、会议室二维码获取信息项页面获取验证码的按钮
		//TODO随后代码优化
		var getCodeBtn = $id("sms_getCodeBtn"),
			regPhoneSmsCodeBtn = $id("regest_phone_attr_getSmsCodeBtn"),
			regMailCodeBtn = $id("regest_mail_attr_getSmsCodeBtn"),
			comPhoneSmsCodeBtn = $id("complete_phone_attr_getSmsCodeBtn"),
			comMailCodeBtn = $id("complete_mail_attr_getSmsCodeBtn"),
			fastmobilePhoneSmsCodeBtn = $id("mobilefast_getCodeBtn"),
			mtqrcodePhoneSmsCodeBtn = $id("mtqrcode_phone_attr_getSmsCodeBtn"),
			comInfoPhoneSmsCodeBtn = $id("completeInfo_phone_attr_getSmsCodeBtn"),
			comInfoMailCodeBtn = $id("completeInfo_mail_attr_getEmailCodeBtn"),
			forgetpwdPhoneSmsCodeBtn = $id("forget_getSmsCode");

		cookie.set("remainTime", "");
		cookie.set("regMobileRemainTime", "");
		cookie.set("regEmailRemainTime", "");
		cookie.set("comMobileRemainTime", "");
		cookie.set("comEmailRemainTime", "");
		cookie.set("fastRemainTime", "");
		cookie.set("mtqrcodePhoneRemainTime", "");
		cookie.set("comInfoPhoneRemainTime", "");
		cookie.set("comInfoMailRemainTime", "");
		cookie.set("forgetPwdPhoneNumber", "");

		var codeBtnAttr = [
			getCodeBtn,
			regPhoneSmsCodeBtn,
			regMailCodeBtn,
			comPhoneSmsCodeBtn,
			comMailCodeBtn,
			fastmobilePhoneSmsCodeBtn,
			mtqrcodePhoneSmsCodeBtn,
			comInfoPhoneSmsCodeBtn,
			comInfoMailCodeBtn,
			forgetpwdPhoneSmsCodeBtn
		];
		var tmpBtn, len = codeBtnAttr.length;
		for (var i = 0; i < len; i++) {
			tmpBtn = codeBtnAttr[i];
			if (tmpBtn) {
				clearInterval(tmpBtn.interval);
				tmpBtn.value = _("Send Again");
                tmpBtn.tagName.toLowerCase() !== 'input' && $(tmpBtn).html(_("Send Again"));

				$(tmpBtn) && $(tmpBtn).removeClass('disabled');
				tmpBtn.disabled = false;
			}
		}
		
		var action = o.action,
			interval,
			isPreview = (window.top.location.search.indexOf('is_preview') !== -1);

		// 双因素认证迭代一：预览页面不支持跳转，直接跳转到注销页面
		if (isPreview && action === 'location') {
			action = 'logout';
		}
		switch (action) {
			case "changePwd":
				activatePage('changePwd', o.userName);
				break;
			case "location":
				btn.disabled = true;

				httpscert_jump(getloginSuccessJumpURL(o.location, o.userName));
				break;
			case "logout":
				httpscert_jump_logout(o.userName, o.pop);
				break;
		}
		//登录成功后启用或关闭心跳状态
		enablePop(o.pop);
	}

	btn.orgValue = btn.value;
	btn.disabled = true;
	if (btn.className && btn.className.indexOf('.get-pass-code') === -1) {
		btn.value = _("Please wait...");
	}
	$btn.addClass('disabled');

	$ajax(params, formid, function(o) {
		setTimeout(function() {
			fn(o);
		}, 1000);
	}, btn, function() {
		btn.disabled = false;
		btn.value = btn.orgValue;
		$btn && $btn.removeClass('disabled');
	});
}

//发给第三方请求(eg:思科)
function sendThird(o, successFn) {
	var me = this,
		json = o.forms;

	$.ajax({
		type: "POST",
		contentType: "application/json",
		dataType: "jsonp",
		crossDomain: true,
		jsonp: "callbackparam", //服务端用于接收callback调用的function名的参数
		url: json.action,
		data: {
			err_flag: json.err_flag,
			buttonClicked: json.buttonClicked,
			redirect_url: json.redirect_url,
			username: json.username,
			password: json.password
		},
		complete: function(resp) {
			if (resp.statusText == 'success') {
				successFn(o, false);
			}
		}
	});
	return;
}

//获取短信认证码后的状态
function afterGetSmsCodeSate(o, params, formid, btn, cdtime) {
	if (!btn) {
		return;
	}
	if (!o.success) {
		
		// 获取短信验证码后，若认证策略已过期，测延时3s后关闭弹窗
		o.backSecretVerification && delayExecutionFn('closeModel');
		$(btn).removeClass('disabled');
		var jump = '';
		if (o.url) {
			jump = '&nbsp;<a href="' + htmlEncode(o.url) + '" target="_blank">' + _('Go Now') + '</a>';
		}
		js_alert(formid, o.msg, false, jump);
		btn.value = _("Send Again");
        btn.tagName.toLowerCase() !== 'input' && $(btn).html(_("Send Again"));

		btn.disabled = false;
		return;
	}
	js_alert(formid, _("One-time passcode(OTP) was sent"));
	//cookie.set("phoneNumber",params.userName);
	clearInterval(btn.interval);
	smsSetCookie(formid, cdtime);

	var i = cdtime; //60s后重新获取
	var txt = '';
	btn.interval = setInterval(function() {
		if (i > 0) {
			i--;
			txt = _("Send Again") + "(" + i + ")";
			btn.value = txt;
            btn.tagName.toLowerCase() !== 'input' && $(btn).html(txt);

			btn.disabled = true;
			$(btn).addClass('disabled');
			smsSetCookie(formid, cdtime);
		} else {
			clearInterval(btn.interval);
			if (formid === 'mode_sms') {
				cookie.set("remainTime", "");
			} else if (formid === 'mode_verifyIdentidy') {
				cookie.set("optSmsCodeRemainTime", "");
			} else {
				cookie.set("fastRemainTime", "");
			}
			btn.value = _("Send Again");
            btn.tagName.toLowerCase() !== 'input' && $(btn).html(_("Send Again"));

			btn.disabled = false;
			$(btn).removeClass('disabled');
		}
	}, 1 * 1000);
}

// 设置短信的登录，短信快捷登录，获取密钥发送验证码的倒计时cookie
function smsSetCookie (type, time) {
	switch (type) {
		case 'mode_sms':
			cookie.set("remainTimespan", (new Date()).getTime());
			cookie.set("remainTime", time);
			break;
		case 'mode_verifyIdentidy':
			cookie.set("optSmsCodeRemainTimespan", (new Date()).getTime());
			cookie.set("optSmsCodeRemainTime", time);
			break;
		default:
			cookie.set("fastRemainTimespan", (new Date()).getTime());
			cookie.set("fastRemainTime", time);
			break;
	}
}


function setAllCodeCookie(type, attr, timeValue) {
	if (type === 'regest') {
		cookie.set(TYPE_TIME['reg' + attr].time, timeValue);
		cookie.set(TYPE_TIME['reg' + attr].timespan, (new Date()).getTime());
	} else if (type === "complete") {
		cookie.set(TYPE_TIME['com' + attr].time, timeValue);
		cookie.set(TYPE_TIME['com' + attr].timespan, (new Date()).getTime());
	} else if (type === 'comInfo') {
		cookie.set(TYPE_TIME['comInfo'].time, timeValue);
		cookie.set(TYPE_TIME['comInfo'].timespan, (new Date()).getTime());
	} else if (type === 'forgetpwd') {
		cookie.set(TYPE_TIME['forgetpwd'].time, timeValue);
		cookie.set(TYPE_TIME['forgetpwd'].timespan, (new Date()).getTime());
	}
}
//注册页面获取短信验证码和邮箱验证码之后的状态处理
function afterGetAllCodeState(o, params, formid, btn, cdtime, type, attr) {
	if (!btn) {
		return;
	}
	if (!o.success) {
		btn.disabled = false;
		$(btn).removeClass('disabled');
		js_alert(formid, o.msg);
        btn.tagName.toLowerCase() !== 'input' && $(btn).html(_("Send Again"));

		btn.value = _("Send Again");
		return;
	}
	js_alert(formid, _("One-time passcode (OTP) was sent."));
	if (btn) {
		clearInterval(btn.interval);
	}
	setAllCodeCookie(type, attr, cdtime);

	var i = cdtime,
		txt = ''; //60s后重新获取
	btn.interval = setInterval(function() {
		if (i > 0) {
			i--;
			txt = _("Send Again ") + "(" + i + ")";
			btn.value = txt;
            btn.tagName.toLowerCase() !== 'input' && $(btn).html(txt);

			btn.disabled = true;
			cookie.set();
			if (type === 'regest') {
				cookie.set(TYPE_TIME['reg' + attr].timespan, (new Date()).getTime());
				cookie.set(TYPE_TIME['reg' + attr].time, i);
			} else if (type === 'complete') {
				cookie.set(TYPE_TIME['com' + attr].timespan, (new Date()).getTime());
				cookie.set(TYPE_TIME['com' + attr].time, i);
			} else if (type === 'mtqrcode') {
				cookie.set(TYPE_TIME['mtqrcodeinfo'].timespan, (new Date()).getTime());
				cookie.set(TYPE_TIME['mtqrcodeinfo'].time, i);
			} else if (type === 'completeInfo') {
				cookie.set(TYPE_TIME['comInfo'].timespan, (new Date()).getTime());
				cookie.set(TYPE_TIME['comInfo'].time, i);
			} else if (type === 'forgetpwd') {
				cookie.set(TYPE_TIME['forgetpwd'].timespan, (new Date()).getTime());
				cookie.set(TYPE_TIME['forgetpwd'].time, i);
			}
		} else {
			clearInterval(btn.interval);
			if (type === 'regest') {
				cookie.set(TYPE_TIME['reg' + attr].time, "");
			} else if (type === 'complete') {
				cookie.set(TYPE_TIME['com' + attr].time, "");
			} else if (type === 'mtqrcode') {
				cookie.set(TYPE_TIME['mtqrcodeinfo'].time, "");
			} else if (type === 'completeInfo') {
				cookie.set(TYPE_TIME['comInfo' + attr].time, "");
			} else if (type === 'forgetpwd') {
				cookie.set(TYPE_TIME['forgetpwd'].timespan, (new Date()).getTime());
			}
			btn.value = _("Send Again");

            btn.tagName.toLowerCase() !== 'input' && $(btn).html(_("Send Again"));
			btn.disabled = false;
			$(btn).removeClass('disabled');
		}
	}, 1 * 1000);
}

//获取短信验证码的请求
function getSmsCodeRequest(params, formid, btn, failFn) {
	//成功后干啥
	function fn(o) {
		afterGetSmsCodeSate(o, params, formid, btn, 60);
	}

	btn.orgValue = btn.value;
	btn.disabled = true;
	$(btn).addClass('disabled');
	$ajax(params, formid, fn, btn, failFn);
}

//修改密码的请求
function changePwdRequest(params, formid, btn) {
	//成功后干啥
	function fn(o) {
        var dot1x = getUrlParam('dot1x');
        if((dot1x === '1' || dot1x === '0') && getUrlParam('type') === 'changePwd'){
            activatePage("regAndComAudit");
            $('.reg-and-com-audit .login_head span').html('The password has been changed successfully.');
            return;
        }
		btn.value = btn.orgValue;
		if (!o.success) {
			js_alert(formid, o.msg);
			btn.disabled = false;
			return;
		}
		var i = 3;
		js_alert(formid, _("Password has been changed.") + _("It enters Login page "+ "<b>" + (i) + "</b>" +" seconds later."), true);
		var interval = setInterval(function() {
			if (i > 0) {
				js_alert(formid, _("Password has been changed.") + _("It enters Login page "+ "<b>" + (i--) + "</b>" +" seconds later."), true);
			} else {
				clearInterval(interval);
				btn.disabled = false;
				js_alert(formid, "");
				activatePage('login', 'fromChangePwd');
			}
		}, 1 * 1000);
	}

	btn.orgValue = btn.value;
	btn.value = _("Please wait...");
	btn.disabled = true;
	$ajax(params, formid, fn, btn);
}

//注销请求
function logoutRequest(params, formid, btn) {
	//成功后干啥
	function fn(o) {
		btn.value = btn.orgValue;
		if (!o.success) {
			js_alert(formid, o.msg);
			btn.disabled = false;
			return;
		}
		var i = 3;
		js_alert(formid, _("Logout succeeded.")  + _("It enters the captive portal <b>" + (i) + "</b> second(s) later."), true);
		var interval = setInterval(function() {
			if (i > 0) {
				js_alert(formid, _("Logout succeeded.") + _("It enters the captive portal <b>" + (i--) + "</b> second(s) later."), true);
			} else {
				clearInterval(interval);
				btn.disabled = false;
				js_alert(formid, "");
				activatePage('login');
			}
		}, 1 * 1000);
		enablePop(false);
	}

	btn.orgValue = btn.value;
	btn.value = _("Please wait...");
	btn.disabled = true;
	$ajax(params, formid, fn, btn);
}
//<<---------------按钮事件和请求的绑定-------------


//logout页面当pop=1的时候需要发心跳，同时在离开页面时需要提示
var enablePop = (function() {
	var pop = false,
		interval;
	var plat = String(navigator.platform.toLowerCase());
	var isWin = plat.indexOf("win") == 0;
	var mobile = false;

	function stratQuery() {
		clearInterval(interval);
		interval = setInterval(request, g_querytTime * 1000);
	}
	if (!isWin)
		mobile = true;
	//心跳请求
	function request() {
		var getTimestamp = new Date().getTime();
        var ip = getUrlParam("ip");
        var encryMsg = encryptByTripleDES("timestamp=" + getTimestamp + "&ip=" + ip);
		if (g_queryEffect) {
			$.ajax({
				url: g_querylogutUrl + "?data=" + encryMsg,
				type: "GET",
				success: function(resp) {
					if (window.console && window.console.log) {
						console.log("tick");
					}
				}
			});
		}
	}
	window.onbeforeunload = function(e) {
		if (g_queryEffect) {
			e = e || window.event;
			if (pop && !mobile) {
				var msg = _("Tips: You will log out if you navigate away from this page.");
				e.returnValue = msg;
				return msg;
			}
		}
	};

	return function(enable) {
		pop = enable;
		if (pop && !mobile) {
			request();
			stratQuery();
		} else {
			clearInterval(interval);
		}
	}
})();

//实现html中英文替换
function doLocalHtml() {
	$('*').each(function() {
		if ($(this).attr("_html")) {
			$(this).html(_($(this).attr("_html")));
		}
		if ($(this).attr("_value")) {
			$(this).attr("value", _($(this).attr("_value")));
		}
		if ($(this).attr("_title")) {
			$(this).attr("title", _($(this).attr("_title")));
		}
	});
}
//实现js中英文替换
function _(str) {
	//如果是中文则不处理。
	if (parseInt(getUrlParam("lang")) !== 1) {
		return str;
	}
	var argus = Array.prototype.slice.call(arguments, 1);
	str = g_Language.hasOwnProperty(str) ? g_Language[str] : str;
	return str.replace(/\{(\d+)\}/g, function(m, i) {
		i = parseInt(i, 10);
		if (i >= 0 && i < argus.length) {
			return argus[i];
		} else {
			return m;
		}
	});
}

//定时请求后台,二维码认证
function ajaxQCode() {
	var urlip = getUrlParam('urlip');
	var url = !urlip ? '/ac_portal/qcode_test.html?' + new Date().getTime() :
		'/ac_portal/qcode_test.html?' + new Date().getTime() + "&urlip=" + urlip;
	$.ajax({
		type: 'GET',
		url: url,
		success: function(json) {
			if (json == 1) {
				js_alert("mode_qrcode", _("Authentication succeeded."));
				clearInterval(window.g_setInter);
				setTimeout(function() {
					var jump_url = getUrlParam('url');
					if (jump_url == '') {
						jump_url = '/homepage/index.html?_FLAG=1';
					}
					httpscert_jump(getloginSuccessJumpURL(jump_url));
				}, 500);
			}
		},
		error: function(json) {
			//js_alert("mode_qrcode", _("认证失败"));
		}
	});
}
//定时请求后台,二维码认证
function ajaxWechat() {
	var urlip = getUrlParam('urlip');
	var url = !urlip ? '/ac_portal/wechat_test.html?' + new Date().getTime() :
		'/ac_portal/wechat_test.html?' + new Date().getTime() + "&urlip=" + urlip;
	$.ajax({
		type: 'GET',
		url: url,
		success: function(json) {
			json = json_decode(json);
			//json格式有误，直接return		
			if (!json || !json.success || json.success === 'false' || !json.username || json.username === '') {
				return;
			}
			clearInterval(window.g_setWechatInter);
			url = getUrlParam('url');
			//有url就直接跳转
			if (url !== '') {
				window.location.href = decodeURIComponent(url);
				return;
			}
			//没有url，有username直接跳到注销页面
			username = decodeURIComponent(json.username);
			httpscert_jump_logout(username, 0);
		},
		error: function(json) {}
	});
}
//定时请求后台,微信扫码认证
function ajaxWXscan() {
	var ip = getUrlParam("ip");
	var url = '/staff_auth/query.html';
	$.ajax({
		type: 'GET',
        url: url + "?ip=" + ip + '&d='+ new Date(),
		success: function(json) {
			// json = json_decode(json);
			var status = +json.status;
			var openid,
				username,
				pwd,
				key;
			if (nowTab === 'WXscan') {
				if (status === 2) {
					js_alert("mode_WXscan", "");
					openid = json.openid;
					username = json.username;
					g_WXscanOpenID = openid;
					pwd = json.pwd;
					key = json.key;
					clearInterval(window.g_setWXscanInter);
					var params = {
						opr: 'pwdLogin', //smsLogin表示短信认证登录,pwdLogin表示密码认证登录
						userName: username,
						pwd: pwd,
						auth_tag: key
					};
					//activateTab('pwd');
					loginRequest(params, "mode_password_wx", $id("password_submitBtn"));
				} else if (status === 1) {
					js_alert("mode_WXscan", "");
					activateTab('pwd');
					openid = json.openid;
					js_alert("mode_password", json.msg || _("You have no factors bound. Please log in using account."));
					g_WXscanOpenID = openid;
					clearInterval(window.g_setWXscanInter);
				} else if (status === 4) {
					js_alert("mode_WXscan", json.msg || _("Failed to log in with WeChat because the server cannot be connected."));
				} else {
					js_alert("mode_WXscan", "");
				}
			}
		},
		error: function(json) {}
	});
}
//判断是否是IPv4，v6，返回处理后的location.host
function locationHost() {
	var hostname = location.hostname,
		host = location.host,
		port = location.port;
	// 如果是IPv6，并且没有中括号，则加上
	if (hostname.indexOf(":") >= 0) {
		// 如果有中括号
		if (/^\[.*\]$/.test(hostname)) {
			//hostname = hostname.slice(1, hostname.length-1);
		} else {
			hostname = "[" + hostname + "]";
		}
		// IE在IPv6下host有误，IP不带中括号
		host = hostname + (port ? (":" + port) : "");
	}
	return host;
}

//生成跳转登陆页面的url,端口为80
function createLoginUrl(type) {
	//默认不传值，如果传了就判断是不是取domain
	if (type === 'domain') {
		var domain = getUrlParam('domain_wechat');
		if (domain) {
			if (window.location.port) {
                return window.location.protocol + '//'  + domain + ':' + window.location.port;
            } else {
                return window.location.protocol + '//'  + domain;
            }
		}
	}
	var hostname = location.hostname,
		host,
		port = location.port;
	// 如果是IPv6，并且没有中括号，则加上
	if (hostname.indexOf(":") >= 0) {
		// 如果有中括号
		if (/^\[.*\]$/.test(hostname)) {
			//hostname = hostname.slice(1, hostname.length-1);
		} else {
			hostname = "[" + hostname + "]";
		}

	}

	host = hostname;

	return location.protocol + "//" + host + (port ? (":" + port) : "");
}

//生成二维码url
function create_qrcode_url(type) {
	var urlIp = getUrlParam("ip"),
		urlR = getUrlParam("r"),
		urlT = getUrlParam("t"),
		urlVlanid = getUrlParam("vlanid"),
		urlc = getUrlParam("c"),
		controller_type = getUrlParam("controller_type"),
		_ID_ = getUrlParam("_ID_"),
		qrcsrv = getUrlParam('qrcsrv'),
		url;
	type = type || 'qcode';
	url = createLoginUrl(type === 'wechat' ? 'domain' : 'domain') + "/ac_portal/" + type + ".html?ip=" + urlIp + "&r=" + urlR + "&t=" + urlT + "&c=" + urlc + "&vlanid=" + urlVlanid + "&controller_type=" + controller_type + "&_ID_=" + _ID_ + "&qrcsrv=" + qrcsrv;


	return url;
}

//生成2维码
function create_qrcode(text, typeNumber, errorCorrectLevel, table) {
	var qr = qrcode(typeNumber || 10, errorCorrectLevel || 'L');
	qr.addData(text);
	qr.make();
	var ua = window.navigator.userAgent;
	//ie6,ie7使用tab
	if (ua.indexOf("MSIE 7") > -1 || ua.indexOf("MSIE 6") > -1) {
		return qr.createTableTag();
	}
	return qr.createImgTag();
};

// 获取当前设备相关信息
function getDeviceInfo() {
	var UA = (navigator.userAgent).toLowerCase();
	return {
		ratio: window.devicePixelRatio || 1,
		isMobile: /(android|mobile|windows (ce|phone)|kindle|blackberry|psp|palm|symbian)/.test(UA),
		isIpad: /ipad/.test(UA),
		isIOS: /(iphone|ipad|ipod|mac os)/.test(UA),
		isAndroid: /android/.test(UA),
		isMQQBrowser: /mqqbrowser/.test(UA),
		isWeChat: /micromessenger/.test(UA)
	}
}

function initWechatLink() {
	var deviceInfo = getDeviceInfo(),
		isPreview = getUrlParam("ispreview");

	if (!deviceInfo.isWeChat && (deviceInfo.isIOS || (deviceInfo.isMQQBrowser && deviceInfo.isAndroid) || isPreview)) {
		var href = deviceInfo.isIOS ? "weixin://" : "http://weixin.qq.com/r/";
		$("#wechat_link").attr("href", href);
		$("#wechat_link").show();
	} else {
		$("#wechat_link").hide();
	}
}

//判断ios11.3及以上
function isIphone11() {
	var UA = String(navigator.userAgent).toLowerCase();
	//是否是ios11以上
	var ver = UA.match(/cpu iphone os 11_(.*?) like/);
	var ios11 = false;
	if (ver) {
		ios11 = parseInt(ver[1], 10) >= 3 ? true : false;
		if (ios11) {
			return ios11;
		}
	}
	//是否是ios12.*及以上
	ver = UA.match(/cpu iphone os (.*?) like/);
	if (ver) {
		ios11 = parseInt(ver[1], 10) > 11 ? true : false;
	}
	//是否是自动弹出的网页（mozilla/5.0 (iphone; cpu iphone os 11_3 like mac os x) applewebkit/601.1.46 (khtml, like gecko) version/9.0 mobile/13b143）	
	return ios11;
}

function changeA() {
	//判断当前版本是不是ios11.3，且是自动弹出portal页面
	var UA = String(navigator.userAgent).toLowerCase();
	var isiphone = UA.indexOf('iphone') > -1;
	var isIos113 = isIphone11();
	var isSafari = UA.indexOf('safari') > -1;
	var isbrowser = UA.indexOf('browser') > -1;
	if (isiphone && isIos113 && !isSafari && !isbrowser) {
		return true;
	}
	return false;
}

function callWechatBrowser_ex() {
	var safariid = getUrlParam("safariid");
	safariid = safariid.toString();
	if (safariid === "1") {
		$(document.getElementById('wx_safari')).html("Communicating with WeChat");
		callWechatBrowser();
	} else if (safariid !== "2"){
		if (changeA()) {
			document.getElementById("wechat_wifi_btn_new").style.display = "";
			document.getElementById('wx_safari').href = window.location.href + (window.location.search != "" ? "&" : "?") + "safariid=1";

		} else {
			document.getElementById("wechat_wifi_btn_old").style.display = "";
		}
	}
}
function callWechatBrowser_ex_wxscan() {
	var safariid = getUrlParam("safariid");
	safariid = safariid.toString();
	if (safariid === "2") {
		$(document.getElementById('wx_safari_scan')).html("Communicating with WeChat");
		var exParams = "userName="+encodeURIComponent(getUrlParam('userName'))+"&pwd="+getUrlParam('pwd')+"&auth_tag="+getUrlParam('auth_tag');
		callWechatBrowser('WXscan', exParams);
	} else if (safariid !== "1") {
		if (changeA()) {
			
			document.getElementById("wechat_wifi_btn_new_wxscan").style.display = "";
			document.getElementById('wx_safari_scan').href = window.location.href + (window.location.search != "" ? "&" : "?") + "safariid=2";
		} else {
			document.getElementById("wechat_wifi_btn_old_wxscan").style.display = "";
		}
	}
}
//短信后微信认证和短信认证或者微信认证不能同时使用
function isIos11_3(){
	
	var smswififlag = getUrlParam("smswififlag");
	var urlip = getUrlParam("ip");
	
	if(changeA())
	{

		//判断当前是否是短信后微信认证，如果是则显示a标签，如果不是则走默认的逻辑
		if(smswififlag == "1"){
			document.getElementById("jump_safari_id").style.display="inline-block";
		}else{
			document.getElementById("sms_submitBtn").style.display="";
		}
				
	}else{
		document.getElementById("sms_submitBtn").style.display="";
	}
}

function jump_safari() {
	if (!smsValidtor('sms')) return false;
	var userName = $id("sms_name").value;
	var pwd = $id("sms_pwd").value;
	var rememberPwd = $id("rememberSms").checked ? '1' : '0';
	document.getElementById('jump_safari_id').href = window.location.href + (window.location.search != "" ? "&" : "?") + "safariidsms=1&opr=smsLogin&userName=" + userName + "&pwd=" + pwd + "&rememberSms=" + rememberSms;
}
function do_encrypt_rc4(src, passwd) {
	src = $.trim(src+'');
	passwd = passwd + '';
	var i, j = 0, a = 0, b = 0, c = 0, temp;
	var plen = passwd.length,
		size = src.length;

	var key = Array(256); //int
	var sbox = Array(256); //int
	var output = Array(size); //code of data
	for (i = 0; i < 256; i++) {
		key[i] = passwd.charCodeAt(i % plen);
		sbox[i] = i;
	}
	for (i = 0; i < 256; i++) {
		j = (j + sbox[i] + key[i]) % 256;
		temp = sbox[i];
		sbox[i] = sbox[j];
		sbox[j] = temp;
	}
	for (i = 0; i < size; i++) {
		a = (a + 1) % 256;
		b = (b + sbox[a]) % 256;
		temp = sbox[a];
		sbox[a] = sbox[b];
		sbox[b] = temp;
		c = (sbox[a] + sbox[b]) % 256;
		temp = src.charCodeAt(i) ^ sbox[c];//String.fromCharCode(src.charCodeAt(i) ^ sbox[c]);
		temp = temp.toString(16);
		if (temp.length === 1) {
			temp = '0' + temp;
		} else if (temp.length === 0) {
			temp = '00';
		}
		output[i] = temp;
	}
	return output.join('');
}
//设置登录页面或完善信息页面、短信快捷登录页面以及会议室二维码信息项页面，如果发送了验证码退出页面又重新进入，验证码继续倒计时
function setOldCodeState() {
	//顺序分别为 注册页面手机号、注册页面邮箱、完善信息页面手机号、完善信息页面邮箱、短信快捷登录页面手机号、会议室二维码页面手机号
	var regPhoneRemainTime = parseInt(cookie.get("regPhoneRemainTime")),
		regPhoneRemainTimeSpan = parseInt(cookie.get("regPhoneRemainTimeSpan")),

		regMailRemainTime = parseInt(cookie.get("regMailRemainTime")),
		regMailRemainTimeSpan = parseInt(cookie.get("regMailRemainTimeSpan")),

		comPhoneRemainTime = parseInt(cookie.get("comPhoneRemainTime")),
		comPhoneRemainTimeSpan = parseInt(cookie.get("comPhoneRemainTimeSpan")),

		comMailRemainTime = parseInt(cookie.get("comMailRemainTime")),
		comMailRemainTimeSpan = parseInt(cookie.get("comMailRemainTimeSpan")),

		fastRemainTime = parseInt(cookie.get("fastRemainTime")),
		fastRemainTimespan = parseInt(cookie.get("fastRemainTimespan")),

		mtqrcodePhoneRemainTime = parseInt(cookie.get("mtqrcodePhoneRemainTime")),
		mtqrcodePhoneRemainTimeSpan = parseInt(cookie.get("mtqrcodePhoneRemainTimeSpan")),

		comInfoPhoneRemainTime = parseInt(cookie.get("comInfoPhoneRemainTime")),
		comInfoPhoneRemainTimeSpan = parseInt(cookie.get("comInfoPhoneRemainTimeSpan")),

		optSmsCodeRemainTime = parseInt(cookie.get("optSmsCodeRemainTime")),
		optSmsCodeRemainTimeSpan = parseInt(cookie.get("optSmsCodeRemainTimeSpan")),

		comInfoMailRemainTime = parseInt(cookie.get("comInfoMailRemainTime")),
		comInfoMailRemainTimeSpan = parseInt(cookie.get("comInfoMailRemainTimeSpan"));

	var timeArr = [regPhoneRemainTime, regMailRemainTime, comPhoneRemainTime, comMailRemainTime, fastRemainTime, mtqrcodePhoneRemainTime, comInfoPhoneRemainTime, comInfoMailRemainTime, optSmsCodeRemainTime],
		spanArr = [regPhoneRemainTimeSpan, regMailRemainTimeSpan, comPhoneRemainTimeSpan, comMailRemainTimeSpan, fastRemainTimespan, mtqrcodePhoneRemainTimeSpan, comInfoPhoneRemainTimeSpan, comInfoMailRemainTimeSpan, optSmsCodeRemainTimeSpan];

	var btnArr = ['regest_phone_attr_getSmsCodeBtn', 'regest_mail_attr_getEmailCodeBtn', 'complete_phone_attr_getSmsCodeBtn', 'complete_mail_attr_getEmailCodeBtn', 'mobilefast_getCodeBtn', 'mtqrcode_phone_attr_getSmsCodeBtn', 'completeInfo_phone_attr_getSmsCodeBtn', 'completeInfo_mail_attr_getEmailCodeBtn', 'mode_verifyIdentidy-sms_getCodeBtn'],
		inputArr = ['regest_phone_attr', 'regest_mail_attr', 'complete_phone_attr', 'complete_mail_attr', 'mobilefast_name', 'mtqrcode_phone_attr', 'completeInfo_phone_attr', 'completeInfo_mail_attr', 'mode_verifyIdentidy-sms_pwd'];

	regPhoneNumber = cookie.get("regPhoneNumber");
	regMail = cookie.get("regMail");

	comPhoneNumber = cookie.get("comPhoneNumber");
	comMail = cookie.get("comMail");

	fastMobile = cookie.get("fastPhoneNumber");

	mtqrcodePhoneNumber = cookie.get("mtqrcodePhoneNumber");

	comInfoPhoneNunber = cookie.get("comInfoPhoneNunber");
	comInfoMail = cookie.get("comInfoMail");
	optSmsCode = cookie.get("optSmsCode");

	var valueArr = [regPhoneNumber, regMail, comPhoneNumber, comMail, fastMobile, mtqrcodePhoneNumber, comInfoPhoneNunber, comInfoMail, optSmsCode];
	//初始化时如果之前有发送过验证码就继续进行计时
	for (var i = 0; i < timeArr.length; i++) {
		timespan = timeArr[i] - Math.floor(((new Date()).getTime() - parseInt(spanArr[i])) / 1000);
		if (timeArr[i] > 0) {
			if ($id(btnArr[i])) {
				$id(btnArr[i]).disabled = true;
			}
			if ($id(inputArr[i])) {
				$id(inputArr[i]).value = valueArr[i];
			}
			if (i === 0 || i === 1) {
				afterGetAllCodeState({
					success: true
				}, {
					userName: valueArr[i]
				}, "mode_regestUser", $id(btnArr[i]), timespan);
			} else if (i === 2 || i === 3) {
				afterGetAllCodeState({
					success: true
				}, {
					userName: valueArr[i]
				}, "mode_complete", $id(btnArr[i]), timespan);
			} else if (i === 4) {
				afterGetSmsCodeSate({
					success: true
				}, {
					userName: valueArr[i]
				}, "mode_mobile", $id(btnArr[i]), timespan);
			} else if (i === 5) {
				afterGetAllCodeState({
					success: true
				}, {
					userName: valueArr[i]
				}, "mode_mtqrcode_info", $id(btnArr[i]), timespan);
			} else if (i === 8) {
				afterGetAllCodeState({
					success: true
				}, {
					userName: valueArr[i]
				}, "mode_verifyIdentidy", $id(btnArr[i]), timespan);
			} else {
				afterGetAllCodeState({
					success: true
				}, {
					userName: valueArr[i]
				}, "mode_complete_userInfo", $id(btnArr[i]), timespan);
			}
		} else {
			if ($id(inputArr[i])) {
				$id(inputArr[i]).value = valueArr[i];
			}
		}
	}
}
function sendUA () {
	var timeStamp = String(new Date().valueOf());
    $.ajax({
        url: "/terminal_info",
        type: 'POST',
        data:{ 
			tag: timeStamp,
			userAgent: do_encrypt_rc4(navigator.userAgent, timeStamp), 
			platform: do_encrypt_rc4(navigator.platform, timeStamp)
		},
		contentType:"application/x-www-form-urlencoded"
    })
}
$(document).ready(function() {
	sendUA();
	doLocalHtml();
    var isPreview = (window.top.location.search.indexOf('is_preview') !== -1);
	var pop = getUrlParam("pop"),
		type = getUrlParam("type"),
		tabs = getUrlParam('tabs') || '',
		tabsArr = tabs.split('-'),
		remainTime, phoneNumber, timespan;
	if (pop === "1" && type === "logout") {
		enablePop(true);
	}
	//定时请求后台,二维码认证才会发请求
	if (tabsArr.indexOf('qrcode') > -1 && !isPreview && type !== "logout") {
		window.g_setInter = setInterval(ajaxQCode, 5000);
	}
	//定时请求后台,微信认证的二维码认证才会发请求
	if (!isPreview && tabsArr.indexOf('wechat') > -1 && type !== "logout" && !/\/mobile\.html$/.test(window.location.pathname)) {
		window.g_setWechatInter = setInterval(ajaxWechat, 5000);
	}
	remainTime = parseInt(cookie.get("remainTime"));
	phoneNumber = cookie.get("phoneNumber");
	if (remainTime) {
		timespan = remainTime - Math.floor(((new Date()).getTime() - parseInt(cookie.get("remainTimespan"))) / 1000);
		if (timespan > 0) {
			$id("sms_getCodeBtn").disabled = true;
			$id("sms_name").value = phoneNumber;
			afterGetSmsCodeSate({
				success: true
			}, {
				userName: phoneNumber
			}, "mode_sms", $id("sms_getCodeBtn"), timespan);
		}
	} else if (phoneNumber) {
		$id("sms_name").value = phoneNumber;
	}
	setOldCodeState();

	var safariidsms = getUrlParam("safariidsms");
	safariidsms = safariidsms.toString();
	if (safariidsms === "1") {
		var userName = getUrlParam("userName");
		var pwd = getUrlParam("pwd");
		var rememberPwd = getUrlParam("rememberPwd") ? '1' : '0';
		$('#sms_name').attr('value', userName).siblings('label').hide();
		$('#sms_pwd').attr('value', pwd).siblings('label').hide();

		var params = {
			opr: 'smsLogin',
			userName: userName,
			pwd: pwd,
			rememberPwd: rememberPwd
		};
		loginRequest(params, "mode_sms", $id("sms_submitBtn"));
	}

	//如果是通过直接请求的logout页面，需要发个请求通知服务端
	if (type === "logout") {
		$.ajax({
			url: g_smsackUrl,
			type: "GET",
			success: function(resp) {
				if (window.console && window.console.log) {
					console.log("sms_ack");
				}
			}
		});
	}

	$('.login_box_msg').click(function() {
		$(this).hide();
	});

	$(window).resize(function(event) {
		setTimeout(function() {
			onReSizeLoginWin();
		}, 500);
	});
	$(window).trigger('resize');

	$(document).click(function(ev) {
		var $dom = $('#tabUl_bottom_left_more');
		if (!$dom.is(':hidden')) {
			$dom.hide();
		}
	});

	// $(document).mouseout(function(event) {
	// 	var $dom = $(this);
	// 	if (!$dom.is('.auth-way-item') && !$dom.parents('.auth-way-item')[0] &&
	// 		!$dom.is('.more-auth_way-wrap') && !$dom.parents('.more-auth_way-wrap')[0]) {
	// 		$('#tabUl_bottom_left_more').hide();
	// 	}
	// });
});
function onReSizeLoginWin () {
	var ht = window.innerHeight,
		curH = Math.max(+(window.innerHeight-140), 300);
	$('.login-extend-win').height(curH);

	// 调整更多认证的位置
	var $more = $('#tabUl_bottom_left_more');
	if (!$more) {
		return;
	}
	var moreH = (+($more.height()) || 0) + 10,
		top = 40;
	if (ht < 570) {
		top = -moreH;
		$more.addClass('top');
	} else {
		$more.removeClass('top');
	}
	$more.css('top', top);
}
//如果认证方式包含other_oauth即第三方oauth认证时，提前获取图片的base64编码
function initOtherOauthIcon() {
	//第三方oauth服务器的名称
	var oauthSrv = getUrlParam("oauthsrv", true);
	if (oauthSrv !== '') {
		$.ajax({
			type: 'GET',
			url: "/ac_portal/get_oauth_icon?oauthsrv=" + encodeURIComponent(oauthSrv),
			success: function(json) {
				successFn(json);
			},
			error: function(json) {
				error(_("Network connection error occurred."));
			}
		});

		function error(msg) {
			js_alert("mode_other_oauth", _("Network connection error occurred."));
		}

		function successFn(json) {
			g_other_oauth_icon = json;
			$("#other-oauth-icon").attr('src', json);
			// $('img.other-auth').attr('src', json);
			initTabs();
		}
	}
}

//如果认证方式是saml认证时，提前获取图片的base64编码
function initSamlOauthIcon() {
	//第三方oauth服务器的名称
	var samlsrv = getUrlParam("samlsrv", true);
	if (samlsrv !== '') {
		$.ajax({
			type: 'GET',
			url: "/ac_portal/get_saml_icon?samlsrv=" + encodeURIComponent(samlsrv),
			success: function(json) {
				successFn(json);
			},
			error: function(json) {
				error(_("Network connection error occurred."));
			}
		});

		function error(msg) {
			// 请求失败，把默认的搞上去
			$("#saml-oauth-icon").attr('src', g_saml_icon);
			js_alert("mode_saml", _("Network connection error occurred."));
		}

		function successFn(json) {
			g_saml_icon = json;
			$("#saml-oauth-icon").attr('src', json);
			initTabs();
		}
	}
}

//新增加的认证方式WXscan的二维码url获取和拼接
function getWXscanUrlParams() {
    var ip = getUrlParam('ip');
    $.ajax({
        type: 'GET',
        url: '/staff_auth/getparam.html?ip=' + ip,
        success: function(json) {
            successFn(json);
        },
        error: function(json) {
            error(json.msg || _("Network connection error occurred."));
        }
    });

    function error(msg) {
        js_alert("mode_WXscan", msg);
    }

    function successFn(json) {
        var url = "https://open.weixin.qq.com/connect/oauth2/authorize?" + json;
        $("#WXscan_qrcodeImg").html(create_qrcode(url, "12", "L"));
    }
}

function openMoaPage (type) {
    var isPreview = (window.top.location.search.indexOf('is_preview') !== -1);

    // 预览下拦截所有跳转
    if (isPreview) {
        return;
    }
	var prefix;
	if (window.location.href.indexOf('~normal~https~ipdefault-portdefault')>-1) {
        prefix = location.href.replace(/^(.+~normal~https~ipdefault-portdefault).*$/, '$1');
    } else {
		prefix = window.location.protocol + "//" + window.location.hostname + (window.location.port ? ':' + window.location.port: '');
	}
    var url = prefix + "/ac_portal/get_auth_url?auth_type=moa";
    if (type === 'mobile') {
    	url += '&ttype=mobile';
    }
    var targetWndName = "MyWindow";
    var wnd = window.open("",targetWndName);
    var link = document.getElementById("link");
    if (!link) {
        $('body').append('<a id="link" href="javascript:void(0);" style="visibility:hidden;position:absolute;"></a>');
        link = document.getElementById("link");
    }
    if (!link) {
        window.open(url);
    } else {
        link.target = targetWndName;
        link.href = url;
        link.click();
    }
}

/*
    初始化tab状态,处理是一个tab还是多个tab的页面布局,
    这个函数只会运行一次(根据不同的布局可自行修改下面代码)
    在新的页面中会运行多次，因为认证类型图标是认证方式动态改变的
*/
function initTabs() {
    var tabs = getUrlParam("tabs") || '';
	var msg = getUrlParam("msg") || '';
    if (tabs === ""){
    	tabs = "pwd";
    } else if (tabs.indexOf('WXscan') !== -1 || tabs.indexOf('WXscan_closelocal') !== -1) {

			// 开启了【微信绑定后关闭本地密码认证】按钮，隐藏切换密码认证的链接，关闭密码认证
			if (tabs.indexOf('_closelocal') !== -1) {
				tabs = tabs.replace('_closelocal', '')
				g_wxscan_closeLocal = true;
			}

    	tabs = tabs.replace(/^\s*WXscan\-|\-WXscan\s*$/g, '');
    	tabs = tabs.replace('-WXscan-', '-');
    	g_WXscan_enable = true;
    	$('.jump-qrcode_account-link .jump-text')[g_wxscan_closeLocal ? 'hide' : 'show']();
			$('.qrcode-tip').html(g_wxscan_closeLocal ? _('Scan with WeChat') : _('Scan to bind account to validate QR code based authentication'));
    }
    tabs = tabs.split("-");
	if(msg) {
		//第一个认证信息显示提示
		js_alert('mode_login', msg);
	}
    createTabs(tabs);
}
//动态生成tabs
function createTabs(tabs) {
    //如果在js头部复制的话拿不到g_之类的标题数据，会导致渲染失败
    TYPE_TEXT = {
        sms: g_smsTabTitle, //短信认证
        pwd: g_accountTabTitle, //账号密码认证
        wechat: g_wechatTabTitle, //微信认证
        qrcode: g_qrcodeTitle, //访客二维码
        freeauth: "Open authentication",
        mtqrcode: g_mtqrcodeTitle, //会议室二维码
        WXscan: g_wxscanTitle, //微信扫码认证
        mobile: g_smsQuickTitle, //短信快捷登录
        cas: g_casTitle,
        facebook: g_facebookTitle,
        gmail: g_gmailTitle,
        line: g_lineTitle,
        twitter: g_twitterTitle,
        qywechat: g_entwechatTitle,
        dingtalk: g_dingtalkTitle,
				twoAuthOpt: window.g_twoAuthOptTitle || '',  // 新增变量的时候需要考虑自定义模板或者定制页面的影响
        moa: g_moaTitle,
        other_oauth: g_otherTitle,
		saml: window.g_samlTitle || '' // 新增变量的时候需要考虑自定义模板或者定制页面的影响
    }
    //是否要显示注册按钮
    var policy = getUrlParam("policy");
    if (policy) {
        var regHtml = '<a href="javascript:void(0);" style="float:right;line-height:30px;" onclick="activatePage(&quot;regestUser&quot;)">' + g_registerButtonText + '</a>';
        $("#tabsUl_bottom_right").show().html(regHtml);
    }
    if (!tabs) {
        return;
    }
    
    //各种认证方式的显示优先级
    var tabPriotity = {
            other_oauth : 1,
            moa : 2,
            dingtalk : 3,
            qywechat : 4,
            facebook : 5,
            gmail : 6,
            line : 7,
            twitter : 8,
            cas : 9,
            pwd : 10,
            wechat : 11,
            sms : 12,
            mtqrcode : 13,
            qrcode : 14,
            WXscan : 15
    }
    var firstTab = tabs[0];
    tabPriotity[firstTab] = 0;
    var defaultIcons = tabs.sort(function(a, b) { return tabPriotity[a] - tabPriotity[b]; });

    //用来保存所有底部的按钮
    oriTabs = defaultIcons.concat();
    //是否开启快捷登录
    var showMobileSms = false;
    var isMobileSms = getUrlParam("sms");
    if (+isMobileSms === 1) {
        showMobileSms = true;
    }
    var topHtml = []; //组装顶部菜单
    var topTabs = [];
    var headText;
    var i = 0;
    var first = defaultIcons[0];
    if (first === 'pwd' && g_WXscan_enable && !g_wxscan_closeLocal) {
    	first = 'WXscan';
    }
    // 是否包含短信快捷登录，如果有短信快捷登录，顶部的菜单显示优先展示的认证方式和短信快捷登录
    // 2019.4.11要修改为账号密码绑定与手机验证码快捷登录绑定，切换到其他认证方式时不展示短信快捷登录
    // 逻辑改为只要第一个优先展示的认证方式是pwd,顶部渲染为两个，否则为一个
    if (first === 'pwd') {
			 // 若开启了【微信绑定后关闭本地密码认证】，则first显示的为微信快捷登录
			 first = g_wxscan_closeLocal ? 'WXscan' : first
        topTabs = [first, "mobile"];
        for (i = 0; i < topTabs.length; i++) {
            headText = TYPE_TEXT[topTabs[i]] || '';
            topHtml += '<li class="tabs-ul-top_item" style="width: 50%;">';
            topHtml += '<div class="tabs-ul-top_text" onclick="activateTab(&quot;' + htmlEncode(topTabs[i]) + '&quot;)">' + headText;
            topHtml += '</div></li>';
        }
    } else {
        topTabs = [first];
        for (i = 0; i < topTabs.length; i++) {
            headText = TYPE_TEXT[topTabs[i]] || '';
            topHtml += '<li class="tabs-ul-top_item" style="width: 100%;">';
            topHtml += '<div class="tabs-ul-top_text" onclick="activateTab(&quot;' + htmlEncode(topTabs[i]) + '&quot;)">' + headText;
            topHtml += '</div></li>';
        }
       
    }
    //去掉tabs中的第一个展示的，用于生成底部的按钮
    defaultIcons.splice(0, 1);
    $("#tabsUl_top").html(topHtml);
    createBottomIcon(defaultIcons);
    activateTab(topTabs[0]);

    var $otherNav = $("#otherNav");
    if ($otherNav) {
    	//如果只有一个tabs,则隐藏其他方式
	    if (oriTabs.length > 1) {
	        window.hideOtherTabs = false;
	    } else {
	        window.hideOtherTabs = true;
	        $otherNav.hide();
	    }
    }

    if (first === 'qrcode') {
    	first = defaultIcons[0];
    }
    window.FirstTabs = first;
    if (!window.FirstTabs) {
    	$('#mode_qrcode_info .login-head-top_right').hide();
    	$('#mode_qrcode_info .login-head-top_right').hide();
    	$("#return_tools").hide();
        $("#logoHead").show();
        $("#login_tools").show();
    }
}
/**
 * [createBottomIcon 生成底部图标，用于初始化界面和切换tab]
 * @param  {[type]} defaultIcons [description]
 */
function createBottomIcon(defaultIcons) {
    var bottomHtml = ''; //组装底部菜单
    var moreIconHtml = ''; //底部菜单超过4个时，进行多余的组装
    var len = defaultIcons.length,
    	evAction;
    for (var i = 0; i < len; i++) {
        var bottomText,
            imageSrc,
            authWay = htmlEncode(defaultIcons[i]);
        evAction = 'onclick="activateTab(&quot;' + authWay + '&quot;)"';
        if (authWay === 'other_oauth') {
            bottomText = htmlEncode(getUrlParam("oauthsrv", true));
            imageSrc = g_other_oauth_icon;
        } else if (authWay === 'saml') {
            bottomText = htmlEncode(getUrlParam("samlsrv", true)) || TYPE_TEXT[authWay];
            imageSrc = g_saml_icon;
        } else {
        	if (authWay === 'pwd' && g_WXscan_enable) {
        		evAction = 'onclick="activateTab(&quot;WXscan&quot;)"';
        	}
            bottomText = TYPE_TEXT[authWay] || '';
            imageSrc = '../share/res/extended_file/css/img/' + authWay + '.png';
        }
        var tickIcon = i === 0 ? '<img class="active-tick-icon" src="../share/res/extended_file/css/img/tick.png"/>' : '';
        if (len < 7) {
            bottomHtml += '<li class="auth-way-item" title="' + bottomText + '">';
            bottomHtml += '<img class="auth-way-item-icon ' + authWay + '" src="' + imageSrc + '"' + evAction + '/>';
            bottomHtml += tickIcon;
            bottomHtml += '</li>';
        } else {
            if (i < 6) {
                bottomHtml += '<li class="auth-way-item" title="' + bottomText + '">';
                bottomHtml += tickIcon;
                bottomHtml += '<img class="auth-way-item-icon ' + authWay + '" src="' + imageSrc + '"' + evAction + '/>';
                bottomHtml += '</li>';
            } else {
                moreIconHtml += '<li class="auth-way-item" title="' + bottomText + '">';
                moreIconHtml += '<img class="auth-way-item-icon ' + authWay + '" src="' + imageSrc + '"' + evAction + '/>';
                moreIconHtml += '</li>';
            }

        }
    }
    if (len > 6) {
        bottomHtml += '<li class="auth-way-item more-auth_way-item" title="' + _('More') + '">';
        bottomHtml += '<span class="more-auth_way-btn" onclick="changeMoreIconStatus()"></span>';
        bottomHtml += '</li>';
    }

    $("#tabsUl_bottom_left").empty().html(bottomHtml);
    $("#tabUl_bottom_left_more").empty().html('<div class="more-auth_way-outer"><div class="more-auth_way-inner">' + moreIconHtml + '</div></div>');
    $("#tabUl_bottom_left_more").hide();

	$('.more-auth_way-item').bind('mouseover', function(event) {
		$('#tabUl_bottom_left_more').show();
	});
}
//展示或隐藏悬浮的图标
//TODO还要再处理一下鼠标点击页面其他地方时，对悬浮的图标区域进行隐藏
function changeMoreIconStatus() {
    var more = $("#tabUl_bottom_left_more");
    if (more.css('display') === 'none') {
        more.show();
    } else {
        more.hide();
    }
}

/* 主要用于扩展，不同模板有不同的处理*/
function beforeActivateTab (tab, index) {

}
//激活短信认证，或密码认证tab取值sms/pwd(跟initChangeTabMethod关联，只要改initChangeTabMethod即可,定制一般不用改动)
function activateTab(tab, index) {
    var isPreview = (window.top.location.search.indexOf('is_preview') !== -1);
	if ($('#mode_wxscanAccount')) {
        $('#mode_wxscanAccount').hide();
    }
    if (window.g_setWXscanInter) {
    	clearInterval(window.g_setWXscanInter);
    }
    beforeActivateTab(tab, index);
    if (tab === "sms") {
        mode_sms()
    } else if (tab === 'qrcode') {
        mode_qrcode();
    } else if (tab === 'wechat') {
        mode_wechat();
    } else if (tab === 'freeauth') {
        mode_freeauth();
    } else if (tab === 'mtqrcode') {
        mode_mtqrcode();
    } else if (tab === 'mobile') {
        mode_mobile();
    } else if (tab === 'WXscan') {
        mode_WXscan();
        //定时请求后台，如果有微信扫码认证并且是pc端才会发请求，手机端使用拉起微信的方式
        if (!isPreview && getUrlParam('tabs').indexOf('WXscan') > -1 && !/\/mobile\.html$/.test(window.location.pathname)) {
            window.g_setWXscanInter = setInterval(ajaxWXscan, 500);
        }
    } else if (tab === 'pwd') {
        mode_password();
    } else if (tab === 'dingtalk') {
        mode_dingtalk();
    } else if (tab === 'qywechat') {
        mode_qywechat();
    } else if (tab === 'moa') {
        mode_moa();
    } else if (tab === 'facebook') {
        mode_facebook();
    } else if (tab === 'gmail') {
        mode_gmail();
    } else if (tab === 'line') {
        mode_line();
    } else if (tab === 'twitter') {
        mode_twitter();
    } else if (tab === 'cas') {
        mode_cas();
    } else if (tab === 'other_oauth') {
        mode_other_oauth();
    } else if(tab === 'saml') {
		mode_saml();
		} else if (tab === 'twoAuthOpt') {
				mode_twoAuthOpt();
		} else {
        mode_password();
    }

    afterActivateTab(tab, index);
}

/* 主要用于扩展，不同模板有不同的处理*/
function afterActivateTab (tab, index) {
	var changeTabsBak = oriTabs && oriTabs.concat() || [],
		item;
    for (var i = changeTabsBak.length - 1; i >= 0; i--) {
    	item = changeTabsBak[i];
        /*if (tab === 'WXscan' && item === 'pwd') {
            changeTabsBak.splice(i, 1);
        }*/
        /*if(tab === 'WXscan') {
            tab = 'pwd';
        }*/
        if(tab === 'WXscan' || tab === 'mobile'){
        	for(var j =0; j<changeTabsBak.length; j++){
        		if(changeTabsBak[j] === 'pwd'){
                    changeTabsBak.splice(j, 1);
                    changeTabsBak.unshift('pwd');
				}
			}
		}else if(tab === item ){
            changeTabsBak.splice(i, 1);
            changeTabsBak.unshift(tab);
        }

        /*if (tab === 'mobile') {
            if (item === nowTab) {
                changeTabsBak.splice(i, 1);
            }
        }*/
    }
    createBottomIcon(changeTabsBak);

    var showMobileSms = false;
    var isMobileSms = getUrlParam("sms");
    if (+isMobileSms === 1) {
        showMobileSms = true;
    }
    //切换顶部的菜单时，要改变样式
    if (tab !== 'mobile') {
        nowTab = tab;
        if (tab === 'pwd' || (tab === 'WXscan' && g_wxscan_closeLocal)) {
            //如果为密码，顶部为两个
            var topHtml = [];
            var headText;
            var topTabs = [];
            if (showMobileSms) {
                topTabs = [tab, 'mobile'];
                tabWidth = "50%";
            } else {
                topTabs = [tab];
                tabWidth = "100%";
            }

            for (var i = 0; i < topTabs.length; i++) {
                headText = TYPE_TEXT[topTabs[i]] || '';
                topHtml += '<li class="tabs-ul-top_item" style="width:' + tabWidth + ';">';
                topHtml += '<div title="'+ headText +'" class="tabs-ul-top_text" onclick="activateTab(&quot;' + htmlEncode(topTabs[i]) + '&quot;)">' + headText;
                topHtml += '</div></li>';
            }
            $("#tabsUl_top").html(topHtml);
            if (showMobileSms) {
            	$('#tabsUl_top li:first').addClass('selected');
            }
        } else {
            //否则顶部只渲染一个
            var topHtml = [];
            var headText;
            var topTabs = [tab];
            for (var i = 0; i < topTabs.length; i++) {
                headText = TYPE_TEXT[topTabs[i]] || '';
                topHtml += '<li class="tabs-ul-top_item" style="width: 100%;">';
                topHtml += '<div class="tabs-ul-top_text" onclick="activateTab(&quot;' + htmlEncode(topTabs[i]) + '&quot;)">' + headText;
                topHtml += '</div></li>';
            }
            $("#tabsUl_top").html(topHtml);
        }
    } else {
    	$('#tabsUl_top li').removeClass('selected');
    	$('#tabsUl_top li:eq(1)').addClass('selected');
    }
}


function resetScrollTop() {
    $('.mode-operate, .login_result, .login_operate, .mobile-body').scrollTop(0);
}

function handle802dot1x(){
    var dot1x = getUrlParam('dot1x');
    if(dot1x === '1' || dot1x === '0'){
        $('.login-head-top_right').hide();
        $('.download').hide();
        $('.reg-and-com-audit .btn_ok').hide();
        $('.reg-and-com-sueesss .btn_ok').hide();
        $('#return_tools').hide();
    }
}

//激活登录，修改密码，注销页面(根据不同的布局可自行修改下面代码)
function activatePage(type, username, isByUrl, errorMsg) {
    handle802dot1x();
    $("#mode_oauthFailure").hide();
    $("#login_inner").hide();
    $("#mode_logout").hide();
    $("#mode_changePwd").hide();
    $("#mode_forgetPwd").hide();
    $("#mode_regestUser").hide();
    $("#mode_complete").hide();
    $("#mode_login").hide();
    $("#mode_freeauth").hide();
    $("#mode_qrcode_info").hide();
    $("#mode_mtqrcode_info").hide();

    $("#mode_regAndComSuccess").hide(); //注册和完善信息成功显示弹窗
    $("#mode_regAndComAudit").hide(); //注册和完善信息需要审核弹窗

    $("#mode_complete_user").hide(); //终端注册页面点击已经拥有账号的跳转页面
    $("#mode_complete_userInfo").hide(); //在终端注册页面点击已经拥有账号跳转页面提交用户名之后的页面

		$("#mode_download_dynamicCode").hide(); //动态码引导页

    //针对手机隐藏
    $("#logoHead") && $("#logoHead").show();

    $("#login_tools").show();
    $("#changePwd_tools").hide();
    $("#logout_tools").hide();

    $('.login_box_msg').hide();
    $('.win-bg').hide();
    switch (type) {
        case "logout":
        	$("#login_inner").show();// addisclaimer模板的
            $("#mode_logout").show();
            $("#logout_tools").show();
            $("#login_tools").hide();
            if (username) {
                $("#logout_name").html(htmlEncode(username));
            }
            break;
        case "changePwd":
            $('.win-bg').show();
            // $("#login_inner").show();
            $("#mode_changePwd").show();
            // $("#changePwd_tools").show();
            if (username) {
                $("#changePwd_name").val(username);
                $("#changePwd_name").siblings('label').css('opacity', 0);
                if (!isByUrl) {
                    $id("changePwd_name").readOnly = true;
                    $("#changePwd_first").html("Password must be changed upon first login.");
                }
                return;
            }
            $("#changePwd_first").html("");
            $id("changePwd_name").readOnly = false;
            $('.win-bg').show();
            break;
        case "regestUser":
            $('.win-bg').show();
            $("#mode_regestUser").show();
            getSysFields("regest");
            // $("#changePwd_tools").show();
            if (username) {
                $("#regestUser_name").val(username);
                $("#regestUser_name").siblings('label').css('opacity', 0);
                return;
            }
            $('.win-bg').show();
            break;
            //终端自注册页面
        case "completeUserIndex":
            getSysFields("complete");
            $("#mode_complete").show();
            // $("#changePwd_tools").show();
            if (username) {
                $("#complete_username").attr('value', username);
                $("#complete_username").siblings('label').css('opacity', 0);
                $("#complete_username").attr("disabled", "disabled");
                return;
            }
            break;
            //终端自注册页面先跳转至输入用户名页面，提交用户名后跳转至完善信息页面
        case "completeUserUser":
            // getSysFields("complete");
            $("#mode_complete_user").show();
            // $("#changePwd_tools").show();
            break;
            //终端自注册页面先跳转至输入用户名页面，提交用户名后跳转至完善信息页面
        case "completeUserInfo":
            // getSysFields("completeInfo");
            $("#mode_complete_userInfo").show();
            // $("#changePwd_tools").show();
            if (username) {
                $("#completeInfo_username_default").attr('value', username);
                $("#completeInfo_username_default").attr("disabled", "disabled");
            }
            break;
        case "forgetPwd":
            $('.win-bg').show();
            moveToStep(0);
            $("#mode_forgetPwd").show();
            // $("#changePwd_tools").show();
            var username = $("#password_name").val();
            if (username.trim() !== "") {
                $("#find_pwd_username").val(username);
            }
            $('.win-bg').show();
            break;
        case 'mode_qrcode_info':
            $('.win-bg').show();
            window.returnIndex = 'qrcode';
            getQrcodeSysFields();
            $("#mode_qrcode_info").show();
            break;
        case 'mode_mtqrcode_info':
            window.returnIndex = 'mtqrcode';
            $("#mode_mtqrcode_info, .win-bg").show();
            break;
        case 'regAndComSuccess':
            $("#mode_regAndComSuccess").show();
            break;
        case 'regAndComAudit':
            $("#mode_regAndComAudit").show();
            break;
				case 'downdymanicCodeApp':
							// 动态码下载引导页，默认选择Microsoft Authenticator
						$('.win-bg').show();
						$('#mode_download_dynamicCode').show();
						changeDynamicTab('microsoft');
						break;
				case 'getAuthCode':
						// 获取密钥/秘钥弹窗(从动态码指引页打开)
						$('#mode_download_dynamicCode, .win-bg').show();
						initCreditSecret();
						break;
				case 'getOverdueCode': 
						// 获取密钥/秘钥弹窗(从二次认证登录页打开)
						$("#login_inner").show();
						$("#mode_login").show()
						initCreditSecret();
						break;
				case 'twoAuthOpt':
						// 二次认证登录页面
						$("#mode_download_dynamicCode").hide();
						$("#mode_login, #login_inner").show();
						$("#two-auth-mode_dynamicCode").show();
						break;
        case "oauthFailure":
						$("#login_inner").show();
						$("#mode_oauthFailure").show();
						$("#login_tools").hide();
						$("#logout_tools").show();
						if (errorMsg) {
								$("#failureMsg").html(htmlEncode(errorMsg));
						}
						break;
        case "login":
            window.location = createLoginUrl() + "/ac_portal/needauth.html?vlanid=" + getUrlParam("vlanid") + "&urlip=" + getUrlParam("urlip") + "&_ID_=" + getUrlParam("_ID_") + "&url=" + getUrlParam("url");
            break;
        case 'firstTabs':
         	$("#login_inner").show();
            activateTab(window.FirstTabs || 'pwd');
            $("#login_tools").show();
            $("#mode_login").show();
            break;
        // case "frontLogin":
        //     $("#login_inner").show();
        //     activateTab(window.returnIndex || 'pwd', window.pwdTabIndex);
        //     $("#login_tools").show();
        //     $("#mode_login").show();
        //     break;
        default:
            $("#login_inner").show();
            $("#login_tools").show();
            $("#mode_login").show();
    }
    if (type !== 'mode_qrcode_info' && type !== 'mode_mtqrcode_info') {
    	window.returnIndex = '';
    }
    if(getUrlParam('tabs') === 'freeauth'){
        $('#mode_freeauth').show();
    }
}
/*
    实现mode_password显示密码认证的方法，
    mode_sms显示短信认证的方法，主要提供给activateTab使用,
    这个函数只会运行一次(根据不同的布局可自行修改下面代码)
*/
function initChangeTabMethod() {
    var isOriginQrcode; //标志在访客二维码认证中是否直接显示二维码
    var audit = getUrlParam('audit');
    if (+audit === 2) {
        isOriginQrcode = false;
    } else {
        isOriginQrcode = true;
    }
    var mode_password, mode_sms, mode_wechat, mode_qrcode, mode_freeauth, interval_wechat;
    var mode_mtqrcode,
        mode_WXscan,
        mode_mobile,
        mode_dingtalk,
        mode_qywechat,
        mode_moa,
        mode_facebook,
				mode_twoAuthOpt,
        mode_gmail,
        mode_line,
        mode_twitter,
        mode_cas,
		mode_saml,
        mode_other_oauth;
    if (/IE/.test(navigator.userAgent) || /MQQBrowser/.test(navigator.userAgent)) {
        mode_password = function() {
            $("#mode_sms").hide();
            $("#mode_qrcode").hide();
            $("#mode_wechat").hide();
            $("#mode_freeauth").hide();
            $('#mode_mtqrcode').hide();
            $('#mode_WXscan').hide();
            $('#mode_mobile').hide();
            $('#mode_dingtalk').hide();
            $('#mode_qywechat').hide();
						$("#two-auth-mode_dynamicCode").hide();
            $('#mode_moa').hide();
            $('#mode_facebook').hide();
            $('#mode_gmail').hide();
            $('#mode_line').hide();
            $('#mode_twitter').hide();
            $('#mode_cas').hide();
            $('#mode_other_oauth').hide();
			$("#mode_saml").hide();
            if (interval_wechat) clearInterval(interval_wechat);
            interval_wechat = null;
            $("#mode_password").show();
            $(".username .focus").focus();
            $("#login_tools_changePwd").show();
        };

        mode_sms = function() {
            $("#mode_password").hide();
            $("#mode_qrcode").hide();
            $("#mode_wechat").hide();
            $('#mode_mtqrcode').hide();
            $("#mode_freeauth").hide();
            $('#mode_WXscan').hide();
            $('#mode_mobile').hide();
            $('#mode_dingtalk').hide();
