            $('#mode_qywechat').hide();
            $('#mode_moa').hide();
            $('#mode_facebook').hide();
            $('#mode_gmail').hide();
            $('#mode_line').hide();
            $('#mode_twitter').hide();
            $('#mode_cas').hide();
