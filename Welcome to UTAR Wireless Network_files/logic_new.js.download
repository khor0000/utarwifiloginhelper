	if (typeof($('#' + type + 'DomainList').val()) != 'undefined') {
		email = email + $('#' + type + 'DomainList').val();
	}
	//校验密码长度
	// if (regPwd.length < 6 || regPwd.length > 16) {
	// 	if (type === 'regest') {
	// 		js_alert("mode_regestUser", _("密码设置应为6-16个字符"));
