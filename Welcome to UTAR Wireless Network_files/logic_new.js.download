//密码登录的校验
function pwdValidtor() {
	var user = $id("password_name"),
		checked = $id("password_disclaimer") ? $id("password_disclaimer").checked : false,
		pwd = $id("password_pwd");

	if ((user.value.length <= 0) || (pwd.value.length <= 0)) {
		valid = false;
		setPasswordTips(_("Username or password are required."));
		return false;
	} else if (user.value.length > 95) {
		setPasswordTips(_("Username cannot exceed 95 characters."));
		return false;
	} else if (window.g_hasDisclaimer && !checked) {
		setPasswordTips(_("Please read and accept the Terms of Use."));
		return false;
	}
	setPasswordTips("");
	return true;
}

//获取验证码时的校验,主要检查手机号格式，包含原短信认证和现在的短信快捷登录
function getSmsCodeValidtor(type) {
	var user,
		Regx = /^[0-9]*$/;

	if (type === 'fastmobile') {
		user = $id("mobilefast_name");
	} else {
		user = $id("sms_name");
	}

	if (user.value.length <= 0) {
		setSmsTips(type, _("Mobile phone number is required."));
		return false;
	} else if (user.value.length > 20) {
		setSmsTips(type, _("Mobile phone number cannot exceed 20 characters."));
		return false;
	} else if (!Regx.test(user.value)) {
		setSmsTips(type, _("Phone number should contain digits only"));
		return false;
	}
	return true;
}

//短信认证时的校验
function smsValidtor(type) {
	if (!getSmsCodeValidtor(type)) return false;
	var pwd;
	var checked = true;
	if (type !== 'fastmobile') {
		pwd = $id("sms_pwd").value;
		checked = $id("sms_disclaimer") ? $id("sms_disclaimer").checked : true;
	} else {
		pwd = $id("mobilefast_pwd").value;
		checked = $id("sms_fast_disclaimer") ? $id("sms_fast_disclaimer").checked : true;
	}
	if (pwd === "") {
		setSmsTips(type, _("Please enter the verification code."));
		return false;
	}
	if (window.g_hasDisclaimer && !checked) {
		setSmsTips(type, _("Please read and accept the Terms of Use."));
		return false;
	}
	setSmsTips(type, "");
	return true;
}

//修改新密码的时候，对密码强度的修改
function validatePasswordStrength(type) {
	if (g_pstrength && g_pstrength.enable) {
		if (type === 'change') {
			var user = $id("changePwd_name").value.toLowerCase();
			var pwd = $id("changePwd_oldPwd").value;
			var pwd1 = $id("changePwd_newPwd").value;
			if (g_pstrength.noequalname) {
				if (user && pwd1 == user) {
					setChangePwdTips(_("Password and username must not be the same"));
					return false;
				}
			}
			if (g_pstrength.noequalold) {
				if (pwd && pwd1 == pwd) {
					setChangePwdTips(_("New password must be different from the current password."));
					return false;
				}
			}
			if (g_pstrength.limit.enable && g_pstrength.limit.minlen > 1) {
				if (pwd1.length < g_pstrength.limit.minlen) {
					setChangePwdTips(_("Password should contain at least ") + g_pstrength.limit.minlen + _(" characters."));
					return false;
				}
			}
			if (g_pstrength.must.enable) {
				if (g_pstrength.must.num && pwd1.search(/\d/) == -1) {
					setChangePwdTips(_("Password must contain digit."));
					return false;
				}
				if (g_pstrength.must.alph && pwd1.search(/[A-Za-z]/) == -1) {
					setChangePwdTips(_("Password must contain letter."));
					return false;
				}
				if (g_pstrength.must.special && pwd1.search(/[!@#\$%\^&\*\(\)]/) == -1) {
					setChangePwdTips(_("Password must contain special characters (Shift+ digit)."));
					return false;
				}
			}
			return true;
		} else if (type === 'forget') {
			var pwd = $id("find_pwd_pwd").value;
			var pwd1 = $id("find_pwd_pwdcon").value;
			if (g_pstrength.limit.enable && g_pstrength.limit.minlen > 1) {
				if (pwd1.length < g_pstrength.limit.minlen) {
					js_alert("mode_forgetPwd", _("Password should contain at least ") + g_pstrength.limit.minlen + _(" characters."));
					return false;
				}
			}
			if (g_pstrength.must.enable) {
				if (g_pstrength.must.num && pwd1.search(/\d/) == -1) {
					js_alert("mode_forgetPwd", _("Password must contain digit."));
					return false;
				}
				if (g_pstrength.must.alph && pwd1.search(/[A-Za-z]/) == -1) {
					js_alert("mode_forgetPwd", _("Password must contain letter."));
					return false;
				}
				if (g_pstrength.must.special && pwd1.search(/[!@#\$%\^&\*\(\)]/) == -1) {
					js_alert("mode_forgetPwd", _("Password must contain special characters (Shift+ digit)."));
					return false;
				}
			}
		}
		
	} else {
		return true;
	}
}
//忘记密码时的校验
function forgetPwdValidator() {
	var pwd1 = $id("find_pwd_pwd"),
		pwd2 = $id("find_pwd_pwdcon");
	if (pwd1.value.length > 39 || pwd1.value.length === 0) {
		js_alert("mode_forgetPwd", _("Password is required and should contain at least 40 characters."));
		return false;
	} else if (pwd1.value !== pwd2.value) {
		js_alert("mode_forgetPwd", _("The new passwords should be the same."));
		return false;
	}
	//密码强度校验
	if (validatePasswordStrength('forget') === false) {
		return false;
	}
	js_alert("mode_forgetPwd", "");
	return true;
}
//修改密码时的校验
function changePwdValidtor() {
	var user = $id("changePwd_name"),
		password = $id("changePwd_oldPwd"),
		pwd1 = $id("changePwd_newPwd"),
		pwd2 = $id("changePwd_newPwd2");
	if (user.value.length <= 0) {
		setChangePwdTips(_("Username is required."));
		return false;
	} else if (user.value.length > 95) {
		setChangePwdTips(_("Username cannot exceed 95 characters."));
		return false;
	} else if (pwd1.value.length > 39 || pwd1.value.length === 0) {
		setChangePwdTips(_("Password is required and should contain at least 40 characters."));
		return false;
	} else if (pwd1.value !== pwd2.value) {
		setChangePwdTips(_("The new passwords should be the same."));
		return false;
	}
	//密码强度校验
	if (validatePasswordStrength('change') === false) {
		return false;
	}
	setChangePwdTips("");
	return true;
}
