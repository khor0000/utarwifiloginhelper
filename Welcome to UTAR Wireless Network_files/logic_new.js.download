// 兼容IE8，发送Referrer头
function openHref(url, isOpenByALink) {
    var isPreview = (window.top.location.search.indexOf('is_preview') !== -1);
    
    // 预览下拦截所有跳转
    if (isPreview) {
    	return;
	}
	
    var navStr = navigator.userAgent.toLowerCase(),
        isIE8 = navStr.indexOf("msie 8") > 0;
    // 手机上特殊处理这两种认证（需要a标签才能拉起）
    if (changeA() && (url.indexOf('auth_type=gmail') > -1 || url.indexOf('auth_type=dingtalk') > -1)) {
        isOpenByALink = true;
    }

    //修复在第三方系统打开ac的时候由于走https代理而导致页面打开失败问题,完整路径保证协议一致性，非完整路径补全为完整路径
    //这里解决不彻底也没其他方案^^
    if(url.match(location.protocol.indexOf('https') > -1)) {
        url = url.replace(/^(http):/, location.protocol);
    } else if (url.match(/^\//) && url.indexOf('ac_portal') > -1) { //这里要考虑还会不会有其它情况，目前其它情况走原有的逻辑
        url = location.href.replace(/\/ac_portal.+$/, "") + url;
    }

	//如果是saml认证，则将get_auth_url替换成saml_auth_req
	if(url.indexOf('auth_type=saml')  > -1 ) {
		url = url.replace('get_auth_url', 'saml_auth_req');
	}

    if (isIE8 || isOpenByALink) {
        var referLink = document.createElement('a');
        referLink.href = url;
        document.body.appendChild(referLink);
        referLink.click();
    } else {
        location.href = url;
    }
}
//cookie
var cookie = {
	set: function(name, value, time) {
		var cur = new Date();
		/*cookie的生命时长设置为60秒*/
		if (time === undefined) {
			time = 60;
		}
		cur.setTime(cur.getTime() + time * 1000);
		document.cookie = name + "=" + escape(value) + ";expires=" + cur.toGMTString();
	},
	get: function(name) {
		if (document.cookie.length > 0) {
			var arrStr = document.cookie.split(";");
			for (var i = 0; i < arrStr.length; i++) {
				var temp = arrStr[i].split("=");
				if ($.trim(temp[0]) === name) {
					return unescape(temp[1]);
				}
			}
		}
		return "";
	}
};
//ie6,7不支持indexof,加上这个功能
Array.prototype.indexOf = function(obj, start) {
	for (var i = (start || 0), j = this.length; i < j; i++) {
		if (this[i] === obj) {
			return i;
		}
	}
	return -1;
}
//html编码
function htmlEncode(value) {
	return !value ? value : String(value).replace(/&/g, "&amp;").replace(/>/g, "&gt;").replace(/</g, "&lt;").replace(/"/g, "&quot;");
}

//html解码
function htmlDecode(value) {
	return !value ? value : String(value).replace(/&amp;/g, "&").replace(/&gt;/g, ">").replace(/&lt;/g, "<").replace(/&quot;/g, "\"");
}

// 简写方法
function $id(id) {
	return document.getElementById(id);
}

//转换json
function json_decode(str) {
	var json = null;
	try {
        str = str.replace(/[\r\n]/g, '');
		json = eval("(" + str + ')');
	} catch (e) {}
	return json;
}

//获取url参数
function getUrlParam(val, isDecode) {
	var reg = new RegExp("(^|\\?|&)" + val + "=([^&#]*)(\\s|&|$|#)", "i");
	var param = '';
	if (reg.test(location.href)) {
		if (isDecode || val === 'username') {
			param = decodeURIComponent(RegExp.$2);
		} else {
			param = decodeURIComponent(RegExp.$2);
		}
	}
	
	return param || '';
}

//生成随机数的函数
function randomNum(minNum, maxNum) {
	switch (arguments.length) {
		case 1:
			return parseInt(Math.random() * minNum + 1, 10);
			break;
		case 2:
			return parseInt(Math.random() * (maxNum - minNum + 1) + minNum, 10);
			break;
		default:
			return 0;
			break;
	}
}


