                    var emailDomains = attrList[i].attr_value;
                    emailDomains = emailDomains.split('\n');
                    oldAttrName = htmlEncode(attrList[i].attr);
                    attrName = oldAttrName;
                    //多个邮箱域名、下拉
                    attrElement += [
                        '<li class="text-input-wrapper">',
                        '<div class="text-input-field">',
                        '<span class="ellipsis register-item-top-text field-name" title="Email Address"><span class="field-need">*</span>Email Address</span>',
                        '<label class="ellipsis txt_default" for="', fixEmailInputId, '" style="width:180px;">Please Enter ', oldAttrName, '</label>',
                        '<input id="', fixEmailInputId, '" type="text"  mode-name="Email Address" class="input" style="width:180px;"/>'
                    ].join('');
                    attrElement += '<select id="' + type + 'DomainList" class="select-right" style="height:37px;width:81px;display:inline-block;border:none;">';
                    for (var k = 0; k < emailDomains.length; k++) {
                        attrElement += '<option value="' + '@' + emailDomains[k] + '">' + '@' + emailDomains[k] + '</option>';
