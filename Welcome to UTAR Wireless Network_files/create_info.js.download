                        '<label class="ellipsis txt_default" for="', fixEmailInputId, '">', tip, '</label>',
                        '<input id="', fixEmailInputId, '"  mode-name="Email Address" type="text" class="input" />',
                        '</div>',
                        '</li>'
                    ].join('');
                } else {
