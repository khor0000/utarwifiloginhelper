                        '<label class="ellipsis txt_default left-txt-label" for="', fixEmailInputId, '">', isMobile ? 'Email Address' : '', '</label>',
                        '<input id="', fixEmailInputId, '" type="text"  mode-name="Email Addres" class="input select-left-input"/>'
                    ].join('');
                    attrElement += '<select id="' + type + 'DomainList" class="select-right">';
                    for (var k = 0; k < emailDomains.length; k++) {
                        attrElement += '<option value="' + '@' + emailDomains[k] + '">' + '@' + emailDomains[k] + '</option>';
                    }
                    attrElement += '</select></div></li>';
