                } else {
                    $("#" + fixEmailInputId).attr('value', attrList[i].value);
                    $("#" +fixEmailInputId).attr("disabled","disabled");
                }

            } else {
                oldAttrName = ATTR_TEXT[attrList[i].attr] ? ATTR_TEXT[attrList[i].attr] : htmlEncode(attrList[i].attr);
                attrName = oldAttrName;
                var tip = "Please enter " + attrName;
                if (attrList[i].tip && attrList[i].tip !== "")
                    tip = attrList[i].tip;

                //标明是否必填
                if (attrList[i].required) {
                    attrName = '<span class="field-need">*</span>' + attrName;
                }
                fixEmailInputId = type + "_mail_attr";
                if (attrList[i].attr_type === 'text') {
                    attrElement += [
                        '<li class="text-input-wrapper">',
                        '<div class="text-input-field">',
