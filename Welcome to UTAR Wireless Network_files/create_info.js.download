//注册和完善信息页面获取动态的信息项
function getSysFields(type, username) {
    var params = {
        opr: 'query',
        policy: getUrlParam("policy", true), // 自注册策略索引
        policy_type: getUrlParam("policy_type"), // 自注册策略类型, terminal表示注册终端（完善信息）, account表示注册账号
    }
    if (type === 'completeInfo') {
        params.username = username;
    }

    function error(msg) {
        var formid;
        formid = setRegestType(type);
        js_alert(formid, msg);
    }
    $.ajax({
        url: g_url,
        data: params,
        type: "POST",
        success: function(resp) {
            var json = json_decode(resp);
            if (json.success) {
                successFn(json);
            } else {
                error(json.msg || _("Network connection error occurred."));
            }
        },
        error: function(o) {
            error(_("Network connection error occurred."));
        }
    });

    function successFn(json) {
        if (type === 'complete') {
            var titl = _('Register');
            if (json && json.data && json.data.is_local) {
                titl = _('Complete user profile');
            }
            $("#mode_complete .login-head-title").html(titl);
        }
        dealInfoItem(json, type);
    }
}

var captchaCodeURL = '/ac_portal/captcha_register?captcha_type=register';

function updateCheckcodeImg () {
    $('#regest_code_img').attr('src', captchaCodeURL + '&' + new Date().getTime()).show();
}

var checkCodeAttr = [            
    '<li class=" li_press text-input-wrapper">',
    '<div class="text-input-field">',
    '<span class="field-name"><span class="field-need">*</span>Enter the Characters</span>',
    '<label class="ellipsis txt_default captcha_code-label" for="regest_captcha_code">', getDeviceInfo().isMobile ? 'Code' : '', '</label>',
    '<input id="regest_captcha_code" name="regest_captcha_code" mode-name="Characters" type="text" class="input part-input" autocomplete="off" />',
    '<div id="regest_code_area" class="captcha_code-img">' +
    '<img id="regest_code_img" class="get_code_img" alt="Click to refresh." src="' + captchaCodeURL + '" onerror="this.style.display=\'none\'">',
    '<div class="get_code_img">Click to get image again.</div>',
    '</div>',
    '</div>',
    '</li>'
].join('');

//统一处理信息项
function dealInfoItem (json, type) {
    var isMobile = getDeviceInfo().isMobile;

    // 复制返回的数据用于提交时使用
    g_infoback = json.data;
    var group;
    var data = json.data;
    var username = data.username;
    $("#regest_user_form").empty();
    //账号注册页面默认的字段，包括用户名、密码、确认密码
    var regestdefaultAttr = [
        '<li class=" li_press text-input-wrapper">',
        '<div class="text-input-field">',
        '<span class="field-name"><span class="field-need">*</span>Username</span>',
        '<label class="ellipsis txt_default" for="regest_username">', isMobile ? 'Username' : '', '</label>',
        '<input name="m_username" id="regest_username" mode-name="Username" type="text" class="input" autocomplete="off" />',
        '</div>',
        '</li>',
        '<li class=" li_press text-input-wrapper">',
        '<div class="text-input-field">',
        '<span class="field-name"><span class="field-need">*</span>Password</span>',
        '<label class="ellipsis txt_default" for="regest_password">', isMobile ? 'Password' : '', '</label>',
        '<input id="regest_password" name="m_userpass" mode-name="Password" type="password" class="input" autocomplete="off" />',
        '</div>',
        '</li>',
        '<li class=" li_press text-input-wrapper">',
        '<div class="text-input-field">',
        '<span class="field-name"><span class="field-need">*</span>Retype Password</span>',
        '<label class="ellipsis txt_default" for="regest_password_confirm">', isMobile ? 'Retype Password' : '', '</label>',
        '<input id="regest_password_confirm" name="m_userpass" mode-name="Password" type="password" class="input" autocomplete="off" />',
        '</div>',
        '</li>'
    ].join('');

    //终端注册页面默认的字段，只有注册名
    var completedefaultAttr = [
        '<li class=" li_press text-input-wrapper">',
        '<div class="text-input-field">',
        '<span class="field-name"><span class="field-need">*</span>Username</span>',
        '<label class="ellipsis txt_default" for="complete_username">', isMobile ? 'Username' : '', '</label>',
        '<input name="m_username" id="complete_username" mode-name="Username" type="text" class="input" autocomplete="off" />',
        '</div>',
        '</li>'
    ].join('');
    //终端注册完善信息页面,默认为空
    var completeInfoAttr = [
        '<li class=" li_press text-input-wrapper">',
        '<div class="text-input-field">',
        '<span class="field-name"><span class="field-need">*</span>Username</span>',
        '<label class="ellipsis txt_default" for="completeInfo_username_default">', isMobile ? 'Username' : '', '</label>',
        '<input name="m_username" id="completeInfo_username_default" mode-name="Username" type="text" class="input" autocomplete="off" />',
        '</div>',
        '</li>'
    ].join('');

    var attrList = data.attr_list;
    if (type === "regest") {
        $("#regest_user_form").html(regestdefaultAttr);
    } else if (type === "complete") {
        $("#complete_user_form").html(completedefaultAttr);
        if (data.username !== "") {
            $("#complete_username").attr('value', data.username);
            $("#complete_username").attr("disabled", 'disabled');
            $("#complete_top_link").hide();
        }
    } else if (type === 'completeInfo') {
        $("#complete_user_info").html(completeInfoAttr);
    }
    //显示用户所属组时
    if (data.group_enable && type !== "completeInfo") {
        var groupOptions = [];
        groupOptions += '<li class="text-input-wrapper">' +
            '<div class="text-input-field">'+
            '<span class="ellipsis register-item-top-text field-name" title="User Group">User Group</span>'+
            '<select id="' + type + 'GroupList">';
        group = data.group;
        var groupValues = group.attr_value.split('\n');
        if (data.group.value !== "") {
            groupValues.push(data.group.value);
        }
        for (var i = 0; i < groupValues.length; i++) {
            var groupLast,
                val = groupValues[i],
                pos = 0;
            if (!val) {
                break;
            }
            if (val !== '/') {
                pos = val.length -1;
                if (val[pos] === '/') {
                    val = val.substring(1, pos);
                }
                groupLast = val.split('/');
                groupOptions += '<option value="' + groupValues[i] + '">' + groupLast[groupLast.length - 1] + '</option>';
            } else {
                groupOptions += '<option value="' + groupValues[i] + '">' + val + '</option>';
            }
        }
        groupOptions += '</select></div></li>';
        setRegestAndCompleteHtml(type, groupOptions);
        //账号注册和终端注册时对组默认值进行处理
        if (data.group.value !== "") {
            if (type === 'complete') {
                $("#" + type + "GroupList").attr("value", data.group.value);
                $("#" + type + "GroupList").attr("disabled", "disabled");
            } else {
                $("#" + type + "GroupList").attr("value", data.group.value);
            }
