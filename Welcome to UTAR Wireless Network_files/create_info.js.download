                        '<div class="text-input-field ">',
                        '<span class="ellipsis register-item-top-text field-name" title="Email Verification"><span class="field-need">*</span>Email Verification</span>',
                        '<label class="ellipsis txt_default email-pass-label" for="', fixEmailCodeId, '">', isMobile ? 'Email Verification' : '', '</label>',
                        '<input id="', fixEmailCodeId, '" name="emailpass" mode-name="Email Verification" class="input email-pass" value="" type="text"/>',
                        '<input id="', fixEmailInputId, '_getEmailCodeBtn" onclick="return onGetRegestCode(&quot;', type, '&quot;,&quot;', attrList[i].attr, '&quot;);" class="button get-pass-code" type="button" value="Send"/>',
                        '</div>',
                        '</li>'
