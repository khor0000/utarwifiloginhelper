//切换忘记密码步骤
function changeStep(num) {
    var formID = "mode_forgetPwd";
    var forgetFirstStep = $("#mode_forgetPwd .first-step"),
        forgetSecondStep = $("#mode_forgetPwd .second-step"),
        forgetNotBindStep = $("#mode_forgetPwd .notbind-step");
    var stepsArr = [forgetFirstStep, forgetSecondStep, forgetNotBindStep];
    if (num === 1) {
        if ($("#find_pwd_username").val() === "") {
            js_alert(formID, _("Username is required."));
            return false;
        } else if ($("#find_pwd_code").val() === "") {
            js_alert(formID, _("Verification code is required."));
            return false;
        } else {
            js_alert(formID, "");
            onForgetFirstStep(stepsArr, num);
        }
    } else if (num === 0) {
        for (var i = 0; i < stepsArr.length; i++) {
            if (i === num) {
                stepsArr[i].show();
            } else {
                stepsArr[i].hide();
            }
        }
    }

}

//访客二维码切换步骤
function changeQrcodeStep(num) {
    var formID = "mode_forgetPwd";
    var qrcodeFirstStep = $("#mode_qrcode_info .qrcode-first-step"),
        qrcodeSecondStep = $("#mode_qrcode_info .qrcode-second-step");
    var stepsArr = [qrcodeFirstStep, qrcodeSecondStep];
    for (var i = 0; i < stepsArr.length; i++) {
        if (i === num) {
            stepsArr[i].show();
        } else {
            stepsArr[i].hide();
        }
    }
}
//访客二维码页面信息项至扫码跳转步骤
function moveToQrcodeStep(step) {
    switch (step) {
        case 0:
        default:
            changeQrcodeStep(0);
            break;
        case 1:
            submitQrcodeInfoItem('qrcode'); //提交信息项
            break;
    }
}
//忘记密码页面跳转步骤
function moveToStep(step) {
    $("#forgetPwd_submitBtn").removeAttr("disabled");
    $("#forgetPwd_submitBtn").disabled = "";

    switch (step) {
        case 0:
        default:
            changeStep(0);
            break;
        case 1:
            changeStep(1);
            setTimeout(function() {
                $("#find_pwd_pwdcon").blur(function() {
                    if ($("#find_pwd_pwd").val() !== $("#find_pwd_pwdcon").val()) {
                        js_alert("mode_forgetPwd", _("The new passwords entered should be the same."));
                    }
                });
                $("#find_pwd_pwd").blur(function() {
                    if ($("#find_pwd_pwd").val() !== "" && $("#find_pwd_pwdcon").val() !== "") {
                        js_alert("mode_forgetPwd", _("The new passwords entered should be the same."));
                    }
                });
            }, 100);
            break;
        case 2:
            if (g_forgetThirdToken !== "") {
                changeStep(2);
            }
            break;
        case 3:
            changeStep(3);
            break;
    }
}
