                if (attrList[i].tip && attrList[i].tip !== "")
                    tip = attrList[i].tip;
                //标明是否必填
                if (attrList[i].required) {
                    attrName = '<span class="field-need">*</span>' + attrName;
                }
                getAttrId = type + '_' + attrList[i].id + '_attr';
                attrElement += [
                    '<li class="text-input-wrapper">',
                    '<div class="text-input-field">',
                    '<span class="ellipsis register-item-top-text field-name" title="', oldAttrName, '">', attrName, '</span>',
                    '<label class="ellipsis txt_default" for="', getAttrId, '">', tip, '</label>',
                    '<input id="', getAttrId, '"  mode-name="'+oldAttrName+'" type="text" class="input" />',
                    '</div>',
                    '</li>'
                ].join('');
                if (attrList[i].value !== '') {
                    $("#" + getAttrId).attr('value', attrList[i].value);
                    $("#" +getAttrId).attr("disabled","disabled");
                }
            } else {
                oldAttrName = ATTR_TEXT[attrList[i].attr] ? ATTR_TEXT[attrList[i].attr] : htmlEncode(attrList[i].attr);
                attrName = oldAttrName;
                //标明是否必填
                if (attrList[i].required) {
                    attrName = '<span class="field-need">*</span>' + attrName;
                }
                var attrValue = attrList[i].attr_value.split('\n');
                attrElement += [
                    '<li class="text-input-wrapper">',
                    '<div class="text-input-field">',
                    '<span class="ellipsis register-item-top-text field-name" title="', oldAttrName, '">', attrName, '</span>'
                ].join('');
                attrElement += '<select id="' + getAttrId + '">';
                for (var j = 0; j < attrValue.length; j++) {
                    attrElement += '<option value="' + attrValue[j] + '">' + attrValue[j] + '</option>';
                }
                attrElement += '</select></div></li>';
                if (attrList[i].value !== '') {
                    $("#" + getAttrId).attr('value', attrList[i].value);
                    $("#" + getAttrId).attr("disabled","disabled");
                }
            }
        }
    }
    setRegestAndCompleteHtml(type, attrElement);

    //用户注册增加验证码
    if(type === 'regest' || type === 'complete') {
        setRegestAndCompleteHtml(type, checkCodeAttr);
        $('#regest_code_area').on('click', '.get_code_img', function () {
            updateCheckcodeImg();
        });
    }

    setRegestCss(type);
}
//设置注册或者完善信息页面表单内容
function setRegestAndCompleteHtml(type, contentHtml) {
    if (type === 'regest') {
        $('#regest_user_form > li:last-child').after(contentHtml);
    } else if (type === 'complete') {
        $('#complete_user_form > li:last-child').after(contentHtml);
    } else if (type === 'completeInfo') {
        $('#complete_user_info > li:last-child').after(contentHtml);
    }
    //动态生成信息项之后为信息项设置默认值
    setRegestDefaultValue(type);
}
//动态生成信息项后为信息项设置默认值
function setRegestDefaultValue (type) {
    var infoData = g_infoback;
    var attrs = infoData.attr_list;

    //对组默认值进行处理

    var remainAttrs = [];
    for (var i = 0; i < attrs.length; i++) {
        //先将内置的手机号码和邮箱账号的提取出来
        if (attrs[i].build_in && attrs[i].attr === 'phone') {
            hasBuildPhone = true;
        } else if (attrs[i].build_in && attrs[i].attr === 'mail') {
            hasBuildEmail = true;
        } else {
            //剩下的属性
            remainAttrs.push(attrs[i]);
        }
        if (attrs[i].attr === 'phone') {
            var attrId = type + '_phone_attr';
            if (attrs[i].value !== "") {
                $("#" + attrId).attr("value", attrs[i].value);
                $("#" + attrId).attr("disabled", "disabled");
            } else if (attrs[i].value_default !== "") {
                $("#" + attrId).attr("value", attrs[i].value_default);
                $("#" + attrId).attr("disabled", false);
            }
        } else if (attrs[i].attr === 'mail') {
            var attrId = type + '_mail_attr';
            if (attrs[i].value !== "") {
                $("#" + attrId).attr("value", attrs[i].value);
                $("#" + attrId).attr("disabled", "disabled");
            } else if (attrs[i].value_default !== "") {
                $("#" + attrId).attr("value", attrs[i].value_default);
                $("#" + attrId).attr("disabled", false);
            }
        } else {
            if (attrs[i].value !== '') {
                $('#' + type + '_' + attrs[i].id + '_attr').attr("value", attrs[i].value);
                $('#' + type + '_' + attrs[i].id + '_attr').attr("disabled", "disabled");
            } else if (attrs[i].value_default !== '') {
                $('#' + type + '_' + attrs[i].id + '_attr').attr("value", attrs[i].value_default);
                $('#' + type + '_' + attrs[i].id + '_attr').attr("disabled", false);
            }
        }

    }

}
//对注册页面和完善信息页面进行事件绑定和样式调整
//在此处增加对注册页面和完善信息页面的页面校验
//1.用户名失去焦点----发请求校验该用户名是否注册
//2.手机号失去焦点----发请求校验该手机号码是否激活
//3.邮箱失去焦点-----a.前端校验邮箱输入格式b.发请求校验该邮箱是否激活
//4.密码失去焦点-------本地校验a.密码格式
//5.确认密码失去焦点-----本地校验 a.密码格式 b.两次密码是否输入一致
//6.所有输入框失去焦点时----本地校验，是否必填
function setRegestCss(type) {
    //处理页面基本失去焦点样式逻辑
    var li;
    if (type === 'regest') {
        li = $(".register-user ul li");
    } else if (type === 'complete') {
        li = $(".complete-user ul li");
    } else if (type === 'completeInfo') {
        li = $(".complete-user-info ul li");
    }
    var input;
    if (type === 'regest') {
        input = $(".register-user ul li.password input");
    } else if (type === 'complete') {
        input = $(".complete-user ul li.password input");
    } else if (type === 'completeInfo') {
        input = $(".complete-user-info ul li.password input");
    }
    var li_hover = "li_hover";
    var li_press = "li_press";
    if (type === 'regest') {
        phone_input = $("#regest_mobile_attr");
        email_input = $("#regest_email_attr");
    } else {
        phone_input = $("#complete_mobile_attr");
        email_input = $("#complete_email_attr");
    }

    /*聚焦*/
    $(".focus").focus();
    /*选中*/
    $(input).click(function() {
        $(this).select();
    });

    //提示
    var inputs;
    if (type === 'regest') {
        inputs = $(".register-user .input");
    } else if (type === 'complete') {
        inputs = $(".complete-user .input");
    } else if (type === 'completeInfo') {
        inputs = $(".complete-user-info .input");
    }
    var showLabel = function(opacity) {
        var v = this.value;
        if (this.type !== "password") {
            v = $.trim(v);
        }
        if (v === '') {
            $(this).siblings('label').show();
            $(this).siblings('label').css('opacity', opacity);
        } else {
            $(this).siblings('label').hide();
        }
    }

    inputs.bind('focus', function() {
        showLabel.call(this, 0.5);
    }).bind('keydown', function() {
        $(this).siblings('label').hide();
    }).bind('blur', function() {
        var v = this.value;
        if (this.type !== "password") {
            v = $.trim(v);
        }
        if (v === '') {
            this.value = v;
        }
        showLabel.call(this, 1);
    });
    setTimeout(function() {
        $.each(inputs, function(index, item) {
            if ($.trim(this.value) !== '') {
                $(item).siblings('label').css('opacity', 0);
            }
        });
    }, 800);

    if (!/(Mobile|Android|Windows Phone)/.test(navigator.userAgent)) {
        /*悬停与聚焦后效果*/
        li.hover(function() {
            $(this).addClass(li_hover);
        }, function() {
            $(this).removeClass(li_hover);
        });
    }

    inputs.each(function() {
        $(this).focus(function() {
            $(this).parent().addClass(li_press);
        });
        $(this).blur(function() {
            //处理输入框失去焦点的逻辑
            dealInputBlurAction($(this));
            $(this).parent().removeClass(li_press);
        });
    });
}
//处理注册和完善信息页面输入框失去焦点的逻辑
function dealInputBlurAction(dom) {
    var domId = dom[0].id,
        type = domId.split('_')[0],
        domValue = dom.val(),
        formid,
        nameReg = /[,/]/,
        domReg = /^[^`~!#$%^&*()+=\\|{};:"',/<>?]*$/;

    formid = setRegestType(type);
    if ((domId !== 'regest_username' && domId !== 'regest_password' && domId !== 'regest_password_confirm')&& !domReg.test(domValue)) {
        js_alert(formid, (dom.attr('mode-name') || '') + _(' cannot contain any of the following special characters: ^[^`~!#$%^&*()+=\\|{};:\"\',/<>?]*$ '));
        return;
    }

    if(domId === 'regest_username' && nameReg.test(domValue)){
        js_alert(formid, (dom.attr('mode-name') || '') + _(' cannot contain any of the following special characters: ,/'));
        return;
    }

    switch (domId) {
        // case 'regest_username':
        // checkPhoneEmailUserVal(type, "user", domValue);
        // break;
        // case 'regest_phone_attr':
        // checkPhoneEmailUserVal(type, "mobile", domValue);
        // break;
        // case 'regest_mail_attr':
        // if (typeof($('#' + type + 'DomainList').val()) != 'undefined') {
        // domValue = domValue + $('#' + type + 'DomainList').val();
        // }
        // checkPhoneEmailUserVal(type, "email", domValue);
        // break;
        case 'regest_password_confirm':
            //校验密码长度
            var regPwd = $("#regest_password").val();
            //校验两次密码输入是否一致
            if (domValue !== regPwd && type === 'regest') {
                js_alert("mode_regestUser", _("The new passwords should be the same."));
                return;
            }
        case 'regest_password':
            if (type === 'regest') {
                if (!domValue) {
                    js_alert("mode_regestUser", _("The password is required."));
                    return;
                }
                if (!validateRegestPasswordStrength('mode_regestUser', true)) {
                    return;
                }
            }
            js_alert("mode_regestUser", "");
            break;

        // case 'complete_username':
        // checkPhoneEmailUserVal(type, "user", domValue);
        // break;
        // case 'complete_phone_attr':
        // checkPhoneEmailUserVal(type, "mobile", domValue);
        // break;
        // case 'complete_mail_attr':
        // if (typeof($('#' + type + 'DomainList').val()) != 'undefined') {
        // domValue = domValue + $('#' + type + 'DomainList').val();
        // }
        // checkPhoneEmailUserVal(type, "email", domValue);
        // break;

        // case 'completeInfo_phone_attr':
        // checkPhoneEmailUserVal(type, "mobile", domValue);
        // break;
        // case 'completeInfo_mail_attr':
        // if (typeof($('#' + type + 'DomainList').val()) != 'undefined') {
        // domValue = domValue + $('#' + type + 'DomainList').val();
        // }
        // checkPhoneEmailUserVal(type, "email", domValue);
        // break;

        default:
            break;
    }
}
//校验注册页面的密码强度
function validateRegestPasswordStrength (formid, isFouce) {
    var user = $id("regest_username").value.toLowerCase();
    var pwd = $id("regest_password").value;
    var pwd1 = $id("regest_password_confirm").value;
    formid = formid || 'mode_changePwd';
    if (!isFouce && !pwd) {
        js_alert(formid, _("The password is required."));
        return false;
    }
    if (g_pstrength.noequalname) {
        if (user && pwd == user) {
            js_alert(formid, _("Password and username must not be the same"));
            return false;
        }
    }
    if (!isFouce && pwd && pwd1 !== pwd) {
        js_alert(formid, _("The new passwords should be the same."));
        return false;
    }
    if (g_pstrength.limit && g_pstrength.limit.enable && g_pstrength.limit.minlen > 1) {
        if (pwd.length < g_pstrength.limit.minlen) {
            js_alert(formid, _("Password should contain at least ") + g_pstrength.limit.minlen + _(" characters."));
            return false;
        }
    } else if (pwd.length > 38) {
        js_alert(formid, _("Password cannot exceed 38 characters."));
        return false;
    }
    if (g_pstrength.must.enable) {
        if (g_pstrength.must.num && pwd.search(/\d/) == -1) {
            js_alert(formid, _("Password must contain digit."));
            return false;
        }
        if (g_pstrength.must.alph && pwd.search(/[A-Za-z]/) == -1) {
            js_alert(formid, _("Password must contain letter."));
            return false;
        }
        if (g_pstrength.must.special && pwd.search(/[!@#\$%\^&\*\(\)]/) == -1) {
            js_alert(formid, _("Password must contain special characters (Shift+ digit)."));
            return false;
        }
    }
    return true;
}
//会议室二维码pc端获取动态的信息项的函数，组装成表单
function getMtQrcodeSysFields() {
    var isMobile = getDeviceInfo().isMobile;

    var qcid = $("#mtqrcode_id").val();
    var url = '/ac_portal/mt_infoitem.html?' + "&qcid=" + qcid;
    $.ajax({
        type: 'GET',
        url: url,
        success: function(json) {
            // var json = json_decode(json);
            if (json.success) {
                if(json.info_item && json.info_item.length > 0){
                    activatePage("mode_mtqrcode_info");
                    successFn(json);
                }else {
                    submitMtQrcodeInfo();
                }
            } else {
                error(json.msg || _("Failed obtain the information."));
            }
        },
        error: function(json) {
            error(_("Network connection error occurred."));
            //js_alert("mode_qrcode", _("认证失败"));
        }
    });

    function error(msg) {
        var formid = "mode_mtqrcode_info";
        js_alert(formid, msg);
    }

    function successFn(json) {
        var data = json.info_item;
        var type = 'mtqrcode';
        // 复制返回的数据用于提交时使用
        g_infoback_mtqrcode = json.info_item;
        $("#mode_mtqrcode_info_content").empty();

        var attrElement = []; //对属性列表中的属性进行遍历
        var getAttrId;
        for (var i = 0; i < data.length; i++) {
            getAttrId = type + '_' + data[i].id + '_attr';
            var oldAttrName = htmlEncode(data[i].name);
            var attrName = oldAttrName;
            if (data[i].request) {
                attrName = '<span class="field-need">*</span>' + attrName;
            }
            var id = data[i].id;
            var fixMobileCodeId = type + "_sms_code";


            if (id === 'phone') {
                if (json.sms_enable) {
                    attrElement += [
                        '<li class="text-input-wrapper">',
                        '<div class="text-input-field ">',
                        '<span class="ellipsis register-item-top-text field-name" title="', oldAttrName, '">', attrName, '</span>',
                        '<label class="ellipsis txt_default " for="', getAttrId, '">Please Enter ', oldAttrName, '</label>',
                        '<input id="', getAttrId, '" type="text" name="', getAttrId, '" mode-name="' + oldAttrName + '" class="input" />',
                        '</div>',
                        '</li>'
                    ].join('');
                    //如果sms_enable为true,则在手机号属性后加获取验证码验证框,点击后进行获取验证码的操作
                    attrElement += [
                        '<li class="text-input-wrapper">',
                        '<div class="text-input-field ">',
                        '<span class="ellipsis register-item-top-text field-name" title="SMS Code">SMS Code</span>',
                        '<label class="ellipsis txt_default sms-pass-label" for="', fixMobileCodeId, '">', isMobile ? 'SMS Code' : '', '</label>',
                        '<input id="', fixMobileCodeId, '" name="smspass" mode-name="' + oldAttrName + '" class="input sms-pass" value="" type="text"/>',
                        '<input id="', getAttrId, '_getSmsCodeBtn" onclick="return onGetMtQrcodeInfoCode();" class="button get-pass-code" type="button" value="Send"/>',
                        '</div>',
                        '</li>'
                    ].join('');
                } else {
                    attrElement += [
                        '<li class="text-input-wrapper">',
                        '<div class="text-input-field ">',
                        '<span class="ellipsis register-item-top-text field-name" title="', oldAttrName, '">', attrName, '</span>',
                        '<label class="ellipsis txt_default" for="', getAttrId, '">Please Enter ', oldAttrName, '</label>',
                        '<input id="', getAttrId, '" name="', getAttrId, '" type="text" mode-name="' + oldAttrName + '" class="input" />',
                        '</div>',
                        '</li>'
                    ].join('');
                }

            } else {
                if (data[i].type === 'text') {
                    attrElement += [
                        '<li class="text-input-wrapper">',
                        '<div class="text-input-field ">',
                        '<span class="ellipsis register-item-top-text field-name" title="', oldAttrName, '">', attrName, '</span>',
                        '<label class="ellipsis txt_default" for="', getAttrId, '">Please Enter ', oldAttrName, '</label>',
                        '<input id="', getAttrId, '" name="', getAttrId, '" type="text" mode-name="' + oldAttrName + '" class="input" />',
                        '</div>',
                        '</li>'
                    ].join('');
                } else {
                    var attrValue = data[i].attr_value.split('\n');
                    var attrName = data[i].name;

                    attrElement += '<li class="text-input-wrapper">' +
                        '<div class="text-input-field ">' +
                        '<span class="ellipsis register-item-top-text  field-name" title="'+ oldAttrName+ '">'+ attrName+ '</span>',
                    '<select id="' + getAttrId + '">';
                    for (var j = 0; j < attrValue.length; j++) {
                        attrElement += '<option value="' + attrValue[j] + '">' + attrValue[j] + '</option>';
                    }
                    attrElement += '</select></div></li>';
                }
            }
        }
        setMtQrcodeInfoHtml(attrElement);
        setMtQrcodeInfoCss(type, data);
    }
}
//设置会议室二维码界面输入字段的限制
function setMtQrcodeInfoCss(type, data) {
    //处理页面基本失去焦点样式逻辑
    var li = $(".mtqrcode-info .login_operate ul li");
    var input = $(".mtqrcode-info .login_operate ul li.password input");
    var li_hover = "li_hover";
    var li_press = "li_press";

    /*聚焦*/
    $(".focus").focus();
    /*选中*/
    $(input).click(function() {
        $(this).select();
    });

    //提示
    var inputs = $('.mtqrcode-info .login_operate .input');
    var showLabel = function(opacity) {
        var v = this.value;
        if (this.type !== "password") {
            v = $.trim(v);
        }
        if (v === '') {
            $(this).siblings('label').show();
            $(this).siblings('label').css('opacity', opacity);
        } else {
            $(this).siblings('label').hide();
        }
    }

    inputs.bind('focus', function() {
        showLabel.call(this, 0.5);
    }).bind('keydown', function() {
        $(this).siblings('label').hide();
    }).bind('blur', function() {
        var v = this.value;
        if (this.type !== "password") {
            v = $.trim(v);
        }
        if (v === '') {
            this.value = v;
        }
        showLabel.call(this, 1);
    });
    setTimeout(function() {
        $.each(inputs, function(index, item) {
            if ($.trim(this.value) !== '') {
                $(item).siblings('label').css('opacity', 0);
            }
        });
    }, 800);

    if (!/(Mobile|Android|Windows Phone)/.test(navigator.userAgent)) {
        /*悬停与聚焦后效果*/
        li.hover(function() {
            $(this).addClass(li_hover);
        }, function() {
            $(this).removeClass(li_hover);
        });
    }

    inputs.each(function() {
        $(this).focus(function() {
            $(this).parent().addClass(li_press);
        });
        $(this).blur(function() {
            //处理输入框失去焦点的逻辑
            // dealInputBlurAction($(this));
            var id = this.id.split('_')[1];
            for (var i = 0; i < data.length; i++) {
                if (data[i].id === id) {
                    if (data[i].request) {
                        if (this.value === "") {
                            js_alert("mode_mtqrcode_info", data[i].name+_(" This field is required."));
                            $("#mtqrcode_info_btn").attr("disabled", "disabled");
                        } else {
                            var domReg = /^[^`~!#$%^&*()+=\\|{};:"',/<>?]*$/;
                            if (!domReg.test(this.value)) {
                                js_alert("mode_mtqrcode_info", _('It cannot contain any of the following special characters: ^[^`~!#$%^&*()+=\\|{};:\"\',/<>?]*$'));
                                return;
                            } else {
                                js_alert("mode_mtqrcode_info", "");
                                $("#mtqrcode_info_btn").attr("disabled", false);
                            }
                        }
                    }
                }
            }
            $(this).parent().removeClass(li_press);
        });
    });

}
//将会议室二维码生成的信息项的节点显示在页面上
function setMtQrcodeInfoHtml(contentHtml) {
    $('#mode_mtqrcode_info_content').html(contentHtml);
    setMtQrcodeDefaultValue();
}
//会议室二维码信息项默认值处理
function setMtQrcodeDefaultValue () {
    var attrs = g_infoback_mtqrcode;
    var type = 'mtqrcode';
    for (var i = 0; i < attrs.length; i++) {

        if (attrs[i].default_value !== '') {
            $('#' + type + '_' + attrs[i].id + '_attr').attr("value", attrs[i].default_value);
        }
    }
}
//访客二维码获取动态的信息项的函数，组装成表单
function getQrcodeSysFields() {
    var qrcsrv = getUrlParam('qrcsrv');
    var url = '/ac_portal/qr_infoitem.html?' + "&qrcsrv=" + qrcsrv;
    $.ajax({
        type: 'GET',
        url: url,
        success: function(json) {
            // var json = json_decode(json);
            if (json.success) {
                successFn(json);
            } else {
                error(json.msg || _("Failed obtain the information."));
            }
        },
        error: function(json) {
            error(_("Network connection error occurred."));
        }
    });

    function error(msg) {
        var formid = "mode_qrcode_info";
        js_alert(formid, msg);
    }

    function successFn(json) {
        var data = json.info_item;
        var type = 'qrcode';
        // 复制返回的数据用于提交时使用
        g_infoback_qrcode = json.info_item;
        $("#mode_qrcode_info_content").empty();

        var attrElement = []; //对属性列表中的属性进行遍历
        var getAttrId;
        for (var i = 0; i < data.length; i++) {
            var attrName = data[i].name;
            var oldAttrName = htmlEncode(attrName);
            if (data[i].request) {
                attrName = '<span class="field-need">*</span>' + attrName;
            }
            var id = data[i].id;
            getAttrId = type + '_' + id + '_attr';

            if (data[i].type === 'text') {
                attrElement += [
                    '<li class="text-input-wrapper">',
                    '<div class="text-input-field ">',
                    '<span class="ellipsis  register-item-top-text field-name" title="', oldAttrName, '">', attrName, '</span>',
                    '<label class="ellipsis txt_default" for="', getAttrId, '">Please Enter ', oldAttrName, '</label>',
                    '<input id="', getAttrId, '" type="text" class="input" />',
                    '</div>',
                    '</li>'
                ].join('');
            } else {
                var attrValue = data[i].attr_value.split('\n');
                attrElement += '<li class="text-input-wrapper">' +
                    '<div class="text-input-field ">'+
                    '<span class="ellipsis  register-item-top-text field-name" title="'+ oldAttrName+ '">'+ attrName+ '</span>' +
                '<select id="' + getAttrId + '" style="height:48px;width:312px;">';
                for (var j = 0; j < attrValue.length; j++) {
                    attrElement += '<option value="' + attrValue[j] + '">' + attrValue[j] + '</option>';
                }
                attrElement += '</select></div></li>';
            }

        }
        setQrcodeInfoHtml(attrElement);
        setQrcodeInfoCss(type, data);
    }
}
